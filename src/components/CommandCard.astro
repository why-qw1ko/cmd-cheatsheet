---
import CopyButton from './CopyButton.astro';

interface Variant {
  name: string;
  syntax: string;
  example?: string;
}

interface Props {
  name: string;
  aliases?: string[];
  domain: string;
  category: string;
  tags?: string[];
  description: string;
  syntax?: string;
  platform?: string;
  variants?: Variant[];
  scenarios?: string[];
  related?: string[];
  relatedLinks?: Record<string, string>;
  since?: string;
  example?: string;
}

const {
  name,
  aliases = [],
  domain,
  category,
  tags = [],
  description,
  syntax,
  platform,
  variants = [],
  scenarios = [],
  related = [],
  relatedLinks = {},
  since,
  example,
} = Astro.props;

const hasVariants = variants.length > 0;
const domainLabels: Record<string, string> = {
  linux: 'Linux',
  claudecode: 'Claude Code',
  windows: 'Windows',
};
---

<article class="cmd-card">
  {/* Header */}
  <div class="cmd-card-header">
    <span class="cmd-card-name">{name}</span>
    <span class="cmd-card-category">{category}</span>
    <span class="cmd-card-domain">{domainLabels[domain] || domain}</span>
    {since && <span style="font-size:0.75rem;opacity:0.4;margin-left:auto;">since {since}</span>}
  </div>

  {/* Aliases */}
  {aliases.length > 0 && (
    <div class="cmd-aliases">
      {aliases.map((a) => (
        <span class="cmd-alias">{a}</span>
      ))}
    </div>
  )}

  {/* Tags */}
  {tags.length > 0 && (
    <div class="cmd-tags">
      {tags.map((t) => (
        <span class="cmd-tag">#{t}</span>
      ))}
    </div>
  )}

  {/* Description */}
  <p class="cmd-description">{description}</p>

  {/* Syntax / Variants */}
  {hasVariants ? (
    <div>
      <div class="variant-tabs" role="tablist">
        {variants.map((v, i) => (
          <button
            class={`variant-tab${i === 0 ? ' active' : ''}`}
            role="tab"
            data-tab={`${name}-tab-${i}`}
            aria-selected={i === 0 ? 'true' : 'false'}
          >
            {v.name}
          </button>
        ))}
      </div>
      {variants.map((v, i) => (
        <div class={`variant-panel${i === 0 ? ' active' : ''}`} data-panel={`${name}-tab-${i}`}>
          <div class="cmd-syntax-block">
            <div>
              <div class="cmd-syntax-label">语法</div>
              <code>{v.syntax}</code>
            </div>
            <CopyButton text={v.syntax} />
          </div>
          {v.example && (
            <div class="cmd-example">
              <div class="cmd-example-label">示例</div>
              <code>{v.example}</code>
            </div>
          )}
        </div>
      ))}
    </div>
  ) : (
    <div>
      {syntax && (
        <div class="cmd-syntax-block">
          <div>
            <div class="cmd-syntax-label">语法</div>
            <code>{syntax}</code>
          </div>
          <CopyButton text={syntax} />
        </div>
      )}
      {example && (
        <div class="cmd-example">
          <div class="cmd-example-label">示例</div>
          <code>{example}</code>
        </div>
      )}
    </div>
  )}

  {/* Scenarios */}
  {scenarios.length > 0 && (
    <div class="cmd-scenarios">
      <div class="cmd-scenarios-title">🎯 使用场景</div>
      <ul>
        {scenarios.map((s) => (
          <li>{s}</li>
        ))}
      </ul>
    </div>
  )}

  {/* Related */}
  {related.length > 0 && (
    <div class="cmd-related">
      <span class="cmd-related-label">相关：</span>
      {related.map((r) => {
        const href = relatedLinks[r];
        return href ? <a href={href}>{r}</a> : <span class="cmd-alias">{r}</span>;
      })}
    </div>
  )}
</article>

{/* Tab switching script */}
{hasVariants && (
  <script>
    document.querySelectorAll('.variant-tab').forEach((tab) => {
      tab.addEventListener('click', () => {
        const tabId = tab.getAttribute('data-tab');
        if (!tabId) return;
        const parent = tab.closest('.cmd-card');
        if (!parent) return;
        parent.querySelectorAll('.variant-tab').forEach((t) => {
          t.classList.remove('active');
          t.setAttribute('aria-selected', 'false');
        });
        parent.querySelectorAll('.variant-panel').forEach((p) => {
          p.classList.remove('active');
        });
        tab.classList.add('active');
        tab.setAttribute('aria-selected', 'true');
        const panel = parent.querySelector(`[data-panel="${tabId}"]`);
        if (panel) panel.classList.add('active');
      });
    });
  </script>
)}
