---
interface Command {
  name: string;
  category: string;
}

interface Props {
  commands: Command[];
}

const { commands } = Astro.props;
---

<nav class="floating-nav" id="floating-nav">
  <div class="floating-nav-title">命令导航</div>
  <div class="nav-letter-index" id="nav-letter-index"></div>
  <div class="floating-nav-list" id="nav-list">
    {commands.map((cmd) => (
      <a class="floating-nav-link" href={`#cmd-${cmd.name}`} data-target={cmd.name} data-letter={(cmd.name.replace(/^[^a-zA-Z]*/, '') || cmd.name)[0]?.toUpperCase()}>
        <span>{cmd.name}</span>
      </a>
    ))}
  </div>
</nav>

<script>
  function scrollToCommand(el: Element) {
    if (!el.classList.contains('open')) el.classList.add('open');
    const header = el.querySelector('.accordion-header');
    if (header) {
      const rect = header.getBoundingClientRect();
      const y = window.scrollY + rect.top - 72;
      window.scrollTo({ top: y, behavior: 'smooth' });
    }
  }

  // Click nav link -> scroll to command
  document.getElementById('nav-list')?.addEventListener('click', (e) => {
    const link = (e.target as HTMLElement).closest('.floating-nav-link') as HTMLAnchorElement;
    if (!link) return;
    e.preventDefault();
    const target = link.getAttribute('data-target');
    const el = document.getElementById(`cmd-${target}`);
    if (el) scrollToCommand(el);
  });

  // Letter index click -> filter nav list
  let activeLetter: string | null = null;
  document.getElementById('nav-letter-index')?.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest('.letter-btn') as HTMLElement;
    if (!btn) return;
    const letter = btn.dataset.letter;
    const allLinks = document.querySelectorAll('.floating-nav-link');

    if (activeLetter === letter) {
      // Deselect -> show all
      activeLetter = null;
      btn.classList.remove('active');
      allLinks.forEach(l => (l as HTMLElement).style.display = '');
    } else {
      // Filter to this letter
      activeLetter = letter;
      document.querySelectorAll('.letter-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      allLinks.forEach(l => {
        const el = l as HTMLElement;
        el.style.display = el.dataset.letter === letter ? '' : 'none';
      });
    }
    // Re-run scroll spy after filter
    requestAnimationFrame(setupScrollSpy);
  });

  // Scroll spy
  let scrollSpyObserver: IntersectionObserver | null = null;

  function setupScrollSpy() {
    const items = document.querySelectorAll('.accordion-item');
    const links = document.querySelectorAll('.floating-nav-link') as NodeListOf<HTMLElement>;
    if (!items.length || !links.length) return;

    // Disconnect old observer
    if (scrollSpyObserver) scrollSpyObserver.disconnect();

    scrollSpyObserver = new IntersectionObserver((entries) => {
      for (const entry of entries) {
        if (entry.isIntersecting) {
          const id = entry.target.id.replace('cmd-', '');
          links.forEach(l => l.classList.remove('active'));
          const active = document.querySelector(`.floating-nav-link[data-target="${id}"]`) as HTMLElement;
          if (active && active.style.display !== 'none') {
            active.classList.add('active');
            const navList = document.getElementById('nav-list');
            if (navList) {
              const linkRect = active.getBoundingClientRect();
              const navRect = navList.getBoundingClientRect();
              if (linkRect.top < navRect.top || linkRect.bottom > navRect.bottom) {
                active.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
              }
            }
          }
          break;
        }
      }
    }, { rootMargin: '-72px 0px -65% 0px', threshold: 0 });

    items.forEach(item => scrollSpyObserver!.observe(item));
  }

  setupScrollSpy();
  document.addEventListener('domain-changed', () => {
    activeLetter = null;
    requestAnimationFrame(setupScrollSpy);
  });
</script>
