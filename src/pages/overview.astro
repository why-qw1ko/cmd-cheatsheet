---
import Layout from '../layouts/Layout.astro';

const linuxModules = import.meta.glob('../data/commands/linux/*.json', { eager: true });
const claudeModules = import.meta.glob('../data/commands/claudecode/*.json', { eager: true });
const cmdModules = import.meta.glob('../data/commands/cmd/*.json', { eager: true });
const psModules = import.meta.glob('../data/commands/powershell/*.json', { eager: true });
const npmModules = import.meta.glob('../data/commands/npm/*.json', { eager: true });
const gitModules = import.meta.glob('../data/commands/git/*.json', { eager: true });
const redisModules = import.meta.glob('../data/commands/redis/*.json', { eager: true });
const dockerModules = import.meta.glob('../data/commands/docker/*.json', { eager: true });

function count(mods: Record<string, any>) {
  return Object.entries(mods).filter(([p]) => !p.includes('_meta.json')).length;
}

const domains = [
  { id: 'linux', label: 'Linux', desc: '系统 · 文件 · 进程 · 网络', icon: 'mdi:linux', count: count(linuxModules), color: '#f59e0b' },
  { id: 'cmd', label: 'CMD', desc: '命令提示符 · 系统管理', icon: 'mdi:microsoft-windows', count: count(cmdModules), color: '#3b82f6' },
  { id: 'powershell', label: 'PowerShell', desc: '脚本自动化 · 对象管道', icon: 'mdi:powershell', count: count(psModules), color: '#6366f1' },
  { id: 'claudecode', label: 'Claude Code', desc: 'AI 编程助手 · 交互命令', icon: 'mdi:code-braces', count: count(claudeModules), color: '#d97706' },
  { id: 'npm', label: 'npm', desc: '包管理 · 脚本 · 依赖', icon: 'mdi:npm', count: count(npmModules), color: '#ef4444' },
  { id: 'git', label: 'Git', desc: '版本控制 · 分支 · 协作', icon: 'mdi:git', count: count(gitModules), color: '#f97316' },
  { id: 'redis', label: 'Redis', desc: '缓存 · 队列 · 数据结构', icon: 'mdi:database', count: count(redisModules), color: '#dc2626' },
  { id: 'docker', label: 'Docker', desc: '容器 · 镜像 · Compose', icon: 'mdi:docker', count: count(dockerModules), color: '#0ea5e9' },
];

const totalCommands = domains.reduce((sum, d) => sum + d.count, 0);
---

<Layout title="总览 — Cmd Cheatsheet" description="命令速查站 · 全平台命令分类总览">
  {/* Header */}
  <header class="site-header">
    <div class="header-left">
      <a href="/cmd-cheatsheet/" class="header-logo">
        <span class="header-logo-icon">
          <iconify-icon icon="mdi:console" width="24" height="24"></iconify-icon>
        </span>
        <span class="header-logo-text">Cmd Cheatsheet</span>
      </a>
    </div>

    <div class="header-right">
      <a class="header-link" href="/cmd-cheatsheet/" title="首页">
        <iconify-icon icon="mdi:home-outline" width="18" height="18"></iconify-icon>
        <span>首页</span>
      </a>
      <a class="header-link active" href="/cmd-cheatsheet/overview" title="总览">
        <iconify-icon icon="mdi:view-dashboard-outline" width="18" height="18"></iconify-icon>
        <span>总览</span>
      </a>
      <span class="header-stat-badge">{totalCommands} 条命令</span>
      <a class="header-link" href="https://github.com/why-qw1ko/cmd-cheatsheet" target="_blank" rel="noopener" title="GitHub">
        <iconify-icon icon="mdi:github" width="18" height="18"></iconify-icon>
      </a>
      <button class="header-btn" id="theme-toggle-header" title="切换主题">
        <span class="theme-icon-light">
          <iconify-icon icon="mdi:weather-sunny" width="20" height="20"></iconify-icon>
        </span>
        <span class="theme-icon-dark">
          <iconify-icon icon="mdi:weather-night" width="20" height="20"></iconify-icon>
        </span>
      </button>
    </div>
  </header>

  {/* Mobile top bar */}
  <div class="mobile-topbar" id="mobile-topbar">
    <a class="mobile-btn" href="/cmd-cheatsheet/" aria-label="首页">
      <iconify-icon icon="mdi:home-outline" width="22" height="22"></iconify-icon>
    </a>
    <span class="mobile-topbar-title">总览</span>
    <button class="mobile-btn" id="mobile-theme-btn" aria-label="主题">
      <span class="theme-icon-light"><iconify-icon icon="mdi:weather-sunny" width="20" height="20"></iconify-icon></span>
      <span class="theme-icon-dark"><iconify-icon icon="mdi:weather-night" width="20" height="20"></iconify-icon></span>
    </button>
  </div>

  <div class="overview-body">
    <div class="overview-hero">
      <h1 class="overview-title">
        <iconify-icon icon="mdi:view-dashboard" width="32" height="32" style="color:var(--accent)"></iconify-icon>
        命令分类总览
      </h1>
      <p class="overview-subtitle">{domains.length} 个平台 · {totalCommands} 条命令 · 点击进入对应分类</p>
    </div>

    <div class="overview-grid">
      {domains.map((d) => (
        <a class="overview-card" href={`/cmd-cheatsheet/?domain=${d.id}`} title={`${d.label} · ${d.count} 条命令`}>
          <div class="card-icon" style={`background: ${d.color}18; color: ${d.color}`}>
            <iconify-icon icon={d.icon} width="28" height="28"></iconify-icon>
          </div>
          <div class="card-body">
            <div class="card-head">
              <span class="card-label">{d.label}</span>
              <span class="card-count" style={`background: ${d.color}18; color: ${d.color}`}>{d.count}</span>
            </div>
            <p class="card-desc">{d.desc}</p>
          </div>
        </a>
      ))}
    </div>
  </div>

  <footer class="site-footer overview-footer">
    <span>© 2026 Cmd Cheatsheet</span>
    <div class="footer-links">
      <a href="/cmd-cheatsheet/">首页</a>
      <a href="https://github.com/why-qw1ko/cmd-cheatsheet" target="_blank" rel="noopener">GitHub</a>
    </div>
  </footer>
</Layout>

<script>
  const root = document.documentElement;
  const saved = localStorage.getItem('theme');
  if (saved) root.setAttribute('data-theme', saved);
  else if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
    root.setAttribute('data-theme', 'dark');
  }

  document.getElementById('theme-toggle-header')?.addEventListener('click', () => {
    const current = root.getAttribute('data-theme');
    const next = current === 'dark' ? 'light' : 'dark';
    root.setAttribute('data-theme', next);
    localStorage.setItem('theme', next);
  });
  document.getElementById('mobile-theme-btn')?.addEventListener('click', () => {
    const current = root.getAttribute('data-theme');
    const next = current === 'dark' ? 'light' : 'dark';
    root.setAttribute('data-theme', next);
    localStorage.setItem('theme', next);
  });
</script>

<style>
  .overview-body {
    margin-top: var(--header-h);
    max-width: 1100px;
    margin-left: auto;
    margin-right: auto;
    padding: 36px 24px 40px;
    min-height: calc(100vh - var(--header-h) - 80px);
  }

  .overview-hero {
    text-align: center;
    margin-bottom: 32px;
  }

  .overview-title {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-size: 1.6rem;
    font-weight: 800;
    margin-bottom: 8px;
  }

  .overview-subtitle {
    color: var(--text-muted);
    font-size: 0.9rem;
  }

  /* 4-col grid on desktop, 3 on tablet, 2 on small tablet, 1 on mobile */
  .overview-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 14px;
  }

  .overview-card {
    display: flex;
    flex-direction: column;
    gap: 14px;
    padding: 20px;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 14px;
    text-decoration: none;
    color: var(--text);
    transition: all 0.2s;
    cursor: pointer;
  }

  .overview-card:hover {
    border-color: var(--accent-light);
    box-shadow: 0 4px 20px rgba(0,0,0,0.08);
    transform: translateY(-3px);
  }

  .card-icon {
    width: 48px;
    height: 48px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .card-body {
    flex: 1;
    min-width: 0;
  }

  .card-head {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 4px;
  }

  .card-label {
    font-size: 0.95rem;
    font-weight: 700;
  }

  .card-count {
    font-size: 0.68rem;
    font-weight: 700;
    padding: 1px 7px;
    border-radius: 9999px;
    line-height: 1.5;
  }

  .card-desc {
    font-size: 0.78rem;
    color: var(--text-muted);
    line-height: 1.5;
  }

  .header-link.active {
    color: var(--accent);
    background: var(--tag-bg);
  }

  .overview-footer {
    margin-left: 0;
    margin-right: 0;
    max-width: 1100px;
    margin-left: auto;
    margin-right: auto;
  }

  @media (max-width: 1024px) {
    .overview-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (max-width: 768px) {
    .site-header { display: none; }
    .mobile-topbar { display: flex; }

    .overview-body { padding: 20px 16px 40px; min-height: calc(100vh - var(--header-h) - 60px); }
    .overview-title { font-size: 1.3rem; }
    .overview-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 10px;
    }
    .overview-card { padding: 16px; }
    .card-icon { width: 40px; height: 40px; }
    .card-label { font-size: 0.88rem; }
  }

  @media (max-width: 480px) {
    .overview-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
