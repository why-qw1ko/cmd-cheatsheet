---
import Layout from '../layouts/Layout.astro';
import DomainSidebar from '../components/DomainSidebar.astro';
import CommandNav from '../components/CommandNav.astro';

// Import all command data
const linuxModules = import.meta.glob('../data/commands/linux/*.json', { eager: true });
const claudeModules = import.meta.glob('../data/commands/claudecode/*.json', { eager: true });
const windowsModules = import.meta.glob('../data/commands/windows/*.json', { eager: true });

function loadCommands(mods: Record<string, any>) {
  return Object.entries(mods)
    .filter(([path]) => !path.includes('_meta.json'))
    .map(([, mod]) => (mod as any).default || mod)
    .sort((a, b) => a.name.localeCompare(b.name));
}

const linuxCmds = loadCommands(linuxModules);
const claudeCmds = loadCommands(claudeModules);
const windowsCmds = loadCommands(windowsModules);

const domains = [
  { id: 'linux', label: 'Linux', desc: '系统命令', count: linuxCmds.length,
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2C9.5 2 8 3.5 8 5.5c0 .8.3 1.5.7 2.1C7.3 8.3 6 9.5 6 12c0 2 .8 3.5 1.8 4.7C6.8 17.7 6 19 6 20.5c0 .8.4 1.5 1.2 1.5h9.6c.8 0 1.2-.7 1.2-1.5 0-1.5-.8-2.8-1.8-3.8C17.2 15.5 18 14 18 12c0-2.5-1.3-3.7-2.7-4.4.4-.6.7-1.3.7-2.1C16 3.5 14.5 2 12 2z"/><circle cx="10" cy="9" r="1" fill="currentColor"/><circle cx="14" cy="9" r="1" fill="currentColor"/><path d="M10 14s.5 1 2 1 2-1 2-1"/></svg>` },
  { id: 'claudecode', label: 'Claude Code', desc: 'AI 编程助手', count: claudeCmds.length,
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="3" y="3" width="18" height="18" rx="3"/><path d="M8 12h8M12 8v8" stroke-linecap="round"/></svg>` },
  { id: 'windows', label: 'Windows', desc: '系统命令', count: windowsCmds.length,
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M3 12h8V4H3v8zm0 8h8v-8H3v8zm10 0h8V12h-8v8zm0-16v8h8V4h-8z" stroke-linejoin="round"/></svg>` },
];

const allCommands: Record<string, any[]> = { linux: linuxCmds, claudecode: claudeCmds, windows: windowsCmds };
---

<Layout title="Cmd Cheatsheet — 命令速查站" description="Linux · Claude Code · Windows 常用命令速查">
  {/* ===== Header ===== */}
  <header class="site-header">
    <div class="header-left">
      <a href="/cmd-cheatsheet/" class="header-logo">
        <span class="header-logo-icon">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="4 17 10 11 4 5" /><line x1="12" y1="19" x2="20" y2="19" />
          </svg>
        </span>
        <span class="header-logo-text">Cmd Cheatsheet</span>
      </a>
    </div>

    <div class="header-search">
      <button class="header-search-btn" id="search-trigger">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <span>搜索命令…</span>
        <span class="header-search-kbd">Ctrl K</span>
      </button>
    </div>

    <div class="header-right">
      <span class="header-stat-badge" id="header-stat-badge">63 条命令</span>
      <a class="header-link" href="https://github.com/why-qw1ko/cmd-cheatsheet/releases" target="_blank" rel="noopener" title="更新日志">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
        <span>更新日志</span>
      </a>
      <a class="header-link" href="https://github.com/why-qw1ko/cmd-cheatsheet/issues" target="_blank" rel="noopener" title="反馈问题">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        <span>反馈</span>
      </a>
      <a class="header-link" href="https://github.com/why-qw1ko/cmd-cheatsheet" target="_blank" rel="noopener" title="GitHub">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
        <span>GitHub</span>
      </a>
      <button class="header-btn" id="theme-toggle-header" title="切换主题">
        <span class="theme-icon-light">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
        </span>
        <span class="theme-icon-dark">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
        </span>
      </button>
    </div>
  </header>

  {/* ===== Search Modal ===== */}
  <div class="search-overlay" id="search-overlay">
    <div class="search-modal">
      <div class="search-input-wrap">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <input class="search-input" id="search-input" type="text" placeholder="输入命令名称、描述或标签…" autocomplete="off" />
        <span class="search-kbd-hint" id="search-close-hint">ESC</span>
      </div>
      <div class="search-results" id="search-results">
        <div class="search-empty">输入关键词开始搜索</div>
      </div>
      <div class="search-footer">
        <span><kbd>↑↓</kbd> 导航</span>
        <span><kbd>Enter</kbd> 展开</span>
        <span><kbd>ESC</kbd> 关闭</span>
      </div>
    </div>
  </div>

  {/* ===== Mobile top bar ===== */}
  <div class="mobile-topbar" id="mobile-topbar">
    <button class="mobile-btn" id="mobile-menu-btn" aria-label="菜单">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
    </button>
    <span class="mobile-topbar-title" id="mobile-topbar-title">Cmd Cheatsheet</span>
    <button class="mobile-btn" id="mobile-theme-btn" aria-label="主题">
      <span class="theme-icon-light"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/></svg></span>
      <span class="theme-icon-dark"><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg></span>
    </button>
  </div>
  <div class="mobile-overlay" id="mobile-overlay"></div>

  {/* ===== Body ===== */}
  <div class="body-layout">
    <DomainSidebar domains={domains} />

    <main class="main-area" id="main-area">
      <div class="main-header">
        <h1 class="main-title" id="main-title">
          <span class="title-icon" id="title-icon" set:html={domains[0].icon} />
          <span id="title-text">Linux</span>
        </h1>
        <p class="main-subtitle" id="main-subtitle">共 {linuxCmds.length} 条命令 · 点击展开查看详情</p>
      </div>
      <div id="accordion-container"></div>
    </main>

    <CommandNav commands={linuxCmds} />
  </div>

  <script id="domain-data" type="application/json" set:html={JSON.stringify(allCommands)} />
</Layout>

<script>
  interface Command {
    name: string;
    aliases?: string[];
    domain: string;
    category: string;
    tags?: string[];
    description: string;
    syntax?: string;
    scenarios?: string[];
    related?: string[];
    example?: string;
    variants?: { name: string; syntax: string; example?: string }[];
  }

  const categoryLabels: Record<string, string> = {
    file: '文件', text: '文本', system: '系统', network: '网络',
    process: '进程', session: '会话', config: '配置', review: '审查',
    cli: 'CLI', package: '包管理',
  };
  const domainLabels: Record<string, string> = {
    linux: 'Linux', claudecode: 'Claude Code', windows: 'Windows',
  };
  const domainIcons: Record<string, string> = {
    linux: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2C9.5 2 8 3.5 8 5.5c0 .8.3 1.5.7 2.1C7.3 8.3 6 9.5 6 12c0 2 .8 3.5 1.8 4.7C6.8 17.7 6 19 6 20.5c0 .8.4 1.5 1.2 1.5h9.6c.8 0 1.2-.7 1.2-1.5 0-1.5-.8-2.8-1.8-3.8C17.2 15.5 18 14 18 12c0-2.5-1.3-3.7-2.7-4.4.4-.6.7-1.3.7-2.1C16 3.5 14.5 2 12 2z"/><circle cx="10" cy="9" r="1" fill="currentColor"/><circle cx="14" cy="9" r="1" fill="currentColor"/><path d="M10 14s.5 1 2 1 2-1 2-1"/></svg>`,
    claudecode: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="3" y="3" width="18" height="18" rx="3"/><path d="M8 12h8M12 8v8" stroke-linecap="round"/></svg>`,
    windows: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M3 12h8V4H3v8zm0 8h8v-8H3v8zm10 0h8V12h-8v8zm0-16v8h8V4h-8z" stroke-linejoin="round"/></svg>`,
  };

  const dataEl = document.getElementById('domain-data');
  const allCommands: Record<string, Command[]> = dataEl ? JSON.parse(dataEl.textContent || '{}') : {};

  function escapeHtml(str: string): string {
    return str.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
  }

  function renderAccordion(commands: Command[], domain: string): string {
    return `<div class="accordion-list" id="accordion-list">${commands.map((cmd, i) => {
      const cat = categoryLabels[cmd.category] || cmd.category;
      const aliasStr = cmd.aliases?.length ? `<span class="accordion-alias">${escapeHtml(cmd.aliases.join(', '))}</span>` : '';
      const tagsHtml = cmd.tags?.length ? `<div class="cmd-tags">${cmd.tags.map(t => `<span class="cmd-tag">#${escapeHtml(t)}</span>`).join('')}</div>` : '';

      let syntaxHtml = '';
      if (cmd.variants?.length) {
        const tabs = cmd.variants.map((v, vi) => `<button class="variant-tab${vi === 0 ? ' active' : ''}" data-tab="${cmd.name}-v-${vi}">${escapeHtml(v.name)}</button>`).join('');
        const panels = cmd.variants.map((v, vi) => `<div class="variant-panel${vi === 0 ? ' active' : ''}" data-panel="${cmd.name}-v-${vi}"><div class="cmd-syntax-block"><div><div class="cmd-label">语法</div><code>${escapeHtml(v.syntax)}</code></div><button class="copy-btn" data-copy="${escapeHtml(v.syntax)}">📋 复制</button></div>${v.example ? `<div class="cmd-example-block"><div class="cmd-label">示例</div><code>${escapeHtml(v.example)}</code></div>` : ''}</div>`).join('');
        syntaxHtml = `<div class="variant-tabs" role="tablist">${tabs}</div>${panels}`;
      } else {
        syntaxHtml = (cmd.syntax ? `<div class="cmd-syntax-block"><div><div class="cmd-label">语法</div><code>${escapeHtml(cmd.syntax)}</code></div><button class="copy-btn" data-copy="${escapeHtml(cmd.syntax)}">📋 复制</button></div>` : '') + (cmd.example ? `<div class="cmd-example-block"><div class="cmd-label">示例</div><code>${escapeHtml(cmd.example)}</code></div>` : '');
      }

      const scenariosHtml = cmd.scenarios?.length ? `<div class="cmd-scenarios"><div class="cmd-label">🎯 使用场景</div><ul>${cmd.scenarios.map(s => `<li>${escapeHtml(s)}</li>`).join('')}</ul></div>` : '';
      const relatedHtml = cmd.related?.length ? `<div class="cmd-related"><span class="cmd-label">相关：</span>${cmd.related.map(r => `<span class="cmd-alias-tag">${escapeHtml(r)}</span>`).join('')}</div>` : '';

      return `<div class="accordion-item" id="cmd-${cmd.name}" data-index="${i}">
        <button class="accordion-header">
          <div class="accordion-title">
            <span class="accordion-name">${escapeHtml(cmd.name)}</span>
            <span class="accordion-cat">${escapeHtml(cat)}</span>
            ${aliasStr}
          </div>
          <svg class="accordion-chevron" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
        </button>
        <div class="accordion-body"><div class="accordion-content"><div class="accordion-content-inner">
          ${tagsHtml}<p class="cmd-desc">${escapeHtml(cmd.description)}</p>${syntaxHtml}${scenariosHtml}${relatedHtml}
        </div></div></div>
      </div>`;
    }).join('')}</div>`;
  }

  function renderNav(commands: Command[]) {
    const navList = document.getElementById('nav-list');
    if (!navList) return;
    navList.innerHTML = commands.map(cmd =>
      `<a class="floating-nav-link" href="#cmd-${cmd.name}" data-target="${cmd.name}"><span class="floating-nav-dot"></span><span>${escapeHtml(cmd.name)}</span></a>`
    ).join('');
  }

  // Initial render
  const container = document.getElementById('accordion-container');
  if (container) container.innerHTML = renderAccordion(allCommands['linux'] || [], 'linux');

  // Domain switch
  function switchDomain(domain: string) {
    const commands = allCommands[domain];
    if (!commands) return;

    document.querySelectorAll('.sidebar-btn[data-domain]').forEach(btn => {
      btn.classList.toggle('active', (btn as HTMLElement).dataset.domain === domain);
    });

    const titleIcon = document.getElementById('title-icon');
    const titleText = document.getElementById('title-text');
    const subtitle = document.getElementById('main-subtitle');
    const mobileTitle = document.getElementById('mobile-topbar-title');
    if (titleIcon) titleIcon.innerHTML = domainIcons[domain] || '';
    if (titleText) titleText.textContent = domainLabels[domain] || domain;
    if (subtitle) subtitle.textContent = `共 ${commands.length} 条命令 · 点击展开查看详情`;
    if (mobileTitle) mobileTitle.textContent = domainLabels[domain] || domain;

    if (container) container.innerHTML = renderAccordion(commands, domain);
    renderNav(commands);
    document.dispatchEvent(new CustomEvent('domain-changed'));
    document.dispatchEvent(new CustomEvent('domain-switched'));
  }

  // Sidebar click
  document.getElementById('domain-sidebar')?.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest('.sidebar-btn[data-domain]') as HTMLElement;
    if (btn?.dataset.domain) switchDomain(btn.dataset.domain);
  });

  // Header theme toggle
  document.getElementById('theme-toggle-header')?.addEventListener('click', () => {
    const root = document.documentElement;
    const current = root.getAttribute('data-theme');
    const next = current === 'dark' ? 'light' : 'dark';
    root.setAttribute('data-theme', next);
    localStorage.setItem('theme', next);
  });

  // Mobile theme toggle
  document.getElementById('mobile-theme-btn')?.addEventListener('click', () => {
    const root = document.documentElement;
    const current = root.getAttribute('data-theme');
    const next = current === 'dark' ? 'light' : 'dark';
    root.setAttribute('data-theme', next);
    localStorage.setItem('theme', next);
  });

  // Accordion + copy (event delegation on container)
  document.getElementById('accordion-container')?.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;

    // Copy button
    const copyBtn = target.closest('.copy-btn');
    if (copyBtn) {
      e.stopPropagation();
      const text = copyBtn.getAttribute('data-copy');
      if (text) {
        navigator.clipboard.writeText(text).then(() => {
          copyBtn.textContent = '✅ 已复制';
          setTimeout(() => { copyBtn.textContent = '📋 复制'; }, 2000);
        });
      }
      return;
    }

    // Variant tab
    const variantTab = target.closest('.variant-tab');
    if (variantTab) {
      e.stopPropagation();
      const tabId = (variantTab as HTMLElement).dataset.tab;
      if (!tabId) return;
      const item = (variantTab as HTMLElement).closest('.accordion-item');
      if (!item) return;
      item.querySelectorAll('.variant-tab').forEach(t => t.classList.remove('active'));
      item.querySelectorAll('.variant-panel').forEach(p => p.classList.remove('active'));
      variantTab.classList.add('active');
      item.querySelector(`[data-panel="${tabId}"]`)?.classList.add('active');
      return;
    }

    // Accordion toggle
    const header = target.closest('.accordion-header');
    if (header) {
      const item = header.closest('.accordion-item');
      if (item) item.classList.toggle('open');
    }
  });

  // Nav click (event delegation)
  document.getElementById('floating-nav')?.addEventListener('click', (e) => {
    const link = (e.target as HTMLElement).closest('.floating-nav-link') as HTMLAnchorElement;
    if (!link) return;
    e.preventDefault();
    const targetName = link.dataset.target;
    const el = document.getElementById(`cmd-${targetName}`);
    if (el) {
      if (!el.classList.contains('open')) el.classList.add('open');
      const header = el.querySelector('.accordion-header');
      if (header) {
        const rect = header.getBoundingClientRect();
        window.scrollTo({ top: window.scrollY + rect.top - 72, behavior: 'smooth' });
      }
    }
  });

  // Scroll spy
  function setupScrollSpy() {
    const items = document.querySelectorAll('.accordion-item');
    const links = document.querySelectorAll('.floating-nav-link');
    if (!items.length || !links.length) return;
    const observer = new IntersectionObserver((entries) => {
      for (const entry of entries) {
        if (entry.isIntersecting) {
          const id = entry.target.id.replace('cmd-', '');
          links.forEach(l => l.classList.remove('active'));
          const active = document.querySelector(`.floating-nav-link[data-target="${id}"]`);
          if (active) {
            active.classList.add('active');
            active.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
          }
          break;
        }
      }
    }, { rootMargin: '-80px 0px -60% 0px', threshold: 0 });
    items.forEach(item => observer.observe(item));
  }
  setupScrollSpy();
  document.addEventListener('domain-changed', () => requestAnimationFrame(setupScrollSpy));

  // Search trigger
  const searchOverlay = document.getElementById('search-overlay');
  const searchInput = document.getElementById('search-input') as HTMLInputElement;
  const searchResults = document.getElementById('search-results');

  // Build search index
  interface SearchItem {
    name: string;
    domain: string;
    category: string;
    description: string;
    tags: string[];
    aliases: string[];
    searchText: string;
  }

  const searchIndex: SearchItem[] = [];
  const domainLabelMap: Record<string, string> = { linux: 'Linux', claudecode: 'Claude Code', windows: 'Windows' };

  for (const [domain, cmds] of Object.entries(allCommands)) {
    for (const cmd of cmds) {
      searchIndex.push({
        name: cmd.name,
        domain,
        category: categoryLabels[cmd.category] || cmd.category,
        description: cmd.description,
        tags: cmd.tags || [],
        aliases: cmd.aliases || [],
        searchText: [cmd.name, ...(cmd.aliases || []), cmd.description, cmd.category, ...(cmd.tags || [])].join(' ').toLowerCase(),
      });
    }
  }

  let searchActiveIdx = -1;

  function openSearch() {
    searchOverlay?.classList.add('open');
    searchInput?.focus();
    searchInput.value = '';
    renderSearchResults('');
  }

  function closeSearch() {
    searchOverlay?.classList.remove('open');
    searchActiveIdx = -1;
  }

  function renderSearchResults(query: string) {
    if (!searchResults) return;
    if (!query.trim()) {
      searchResults.innerHTML = '<div class="search-empty">输入关键词开始搜索</div>';
      return;
    }
    const q = query.toLowerCase();
    const matches = searchIndex.filter(item => item.searchText.includes(q)).slice(0, 20);
    if (!matches.length) {
      searchResults.innerHTML = `<div class="search-empty">未找到 "${escapeHtml(query)}" 相关命令</div>`;
      return;
    }
    searchActiveIdx = 0;
    searchResults.innerHTML = matches.map((item, i) => `
      <div class="search-result-item${i === 0 ? ' active' : ''}" data-domain="${item.domain}" data-name="${item.name}">
        <div class="search-result-info">
          <div style="display:flex;align-items:center;gap:8px;">
            <span class="search-result-name">${escapeHtml(item.name)}</span>
            <span class="search-result-cat">${escapeHtml(item.category)}</span>
            <span class="search-result-domain">${escapeHtml(domainLabelMap[item.domain] || item.domain)}</span>
          </div>
          <div class="search-result-desc">${escapeHtml(item.description)}</div>
        </div>
      </div>
    `).join('');
  }

  function navigateSearchResult(delta: number) {
    const items = searchResults?.querySelectorAll('.search-result-item');
    if (!items?.length) return;
    items[searchActiveIdx]?.classList.remove('active');
    searchActiveIdx = Math.max(0, Math.min(items.length - 1, searchActiveIdx + delta));
    items[searchActiveIdx]?.classList.add('active');
    items[searchActiveIdx]?.scrollIntoView({ block: 'nearest' });
  }

  function selectSearchResult() {
    const items = searchResults?.querySelectorAll('.search-result-item');
    const active = items?.[searchActiveIdx] as HTMLElement;
    if (!active) return;
    const domain = active.dataset.domain;
    const name = active.dataset.name;
    if (domain) switchDomain(domain);
    closeSearch();
    setTimeout(() => {
      const el = document.getElementById(`cmd-${name}`);
      if (el) {
        if (!el.classList.contains('open')) el.classList.add('open');
        const h = el.querySelector('.accordion-header');
        if (h) { const r = h.getBoundingClientRect(); window.scrollTo({ top: window.scrollY + r.top - 72, behavior: 'smooth' }); }
      }
    }, 50);
  }

  // Search event handlers
  document.getElementById('search-trigger')?.addEventListener('click', openSearch);
  document.getElementById('search-close-hint')?.addEventListener('click', closeSearch);
  searchOverlay?.addEventListener('click', (e) => {
    if (e.target === searchOverlay) closeSearch();
  });

  searchInput?.addEventListener('input', (e) => {
    renderSearchResults((e.target as HTMLInputElement).value);
  });

  searchInput?.addEventListener('keydown', (e) => {
    if (e.key === 'ArrowDown') { e.preventDefault(); navigateSearchResult(1); }
    else if (e.key === 'ArrowUp') { e.preventDefault(); navigateSearchResult(-1); }
    else if (e.key === 'Enter') { e.preventDefault(); selectSearchResult(); }
    else if (e.key === 'Escape') { closeSearch(); }
  });

  searchResults?.addEventListener('click', (e) => {
    const item = (e.target as HTMLElement).closest('.search-result-item') as HTMLElement;
    if (!item) return;
    const domain = item.dataset.domain;
    const name = item.dataset.name;
    if (domain) switchDomain(domain);
    closeSearch();
    setTimeout(() => {
      const el = document.getElementById(`cmd-${name}`);
      if (el) {
        if (!el.classList.contains('open')) el.classList.add('open');
        const h = el.querySelector('.accordion-header');
        if (h) { const r = h.getBoundingClientRect(); window.scrollTo({ top: window.scrollY + r.top - 72, behavior: 'smooth' }); }
      }
    }, 50);
  });

  // Ctrl+K shortcut
  document.addEventListener('keydown', (e) => {
    if ((e.ctrlKey || e.metaKey) && e.key === 'k') {
      e.preventDefault();
      openSearch();
    }
    if (e.key === 'Escape' && searchOverlay?.classList.contains('open')) {
      closeSearch();
    }
  });
</script>
