---
import Layout from '../layouts/Layout.astro';
import DomainSidebar from '../components/DomainSidebar.astro';
import CommandNav from '../components/CommandNav.astro';

// Import all command data
const linuxModules = import.meta.glob('../data/commands/linux/*.json', { eager: true });
const claudeModules = import.meta.glob('../data/commands/claudecode/*.json', { eager: true });
const cmdModules = import.meta.glob('../data/commands/cmd/*.json', { eager: true });
const psModules = import.meta.glob('../data/commands/powershell/*.json', { eager: true });
const npmModules = import.meta.glob('../data/commands/npm/*.json', { eager: true });
const gitModules = import.meta.glob('../data/commands/git/*.json', { eager: true });
const redisModules = import.meta.glob('../data/commands/redis/*.json', { eager: true });
const dockerModules = import.meta.glob('../data/commands/docker/*.json', { eager: true });

function loadCommands(mods: Record<string, any>) {
  return Object.entries(mods)
    .filter(([path]) => !path.includes('_meta.json'))
    .map(([, mod]) => (mod as any).default || mod)
    .sort((a, b) => a.name.localeCompare(b.name));
}

const linuxCmds = loadCommands(linuxModules);
const claudeCmds = loadCommands(claudeModules);
const cmdCmds = loadCommands(cmdModules);
const psCmds = loadCommands(psModules);
const npmCmds = loadCommands(npmModules);
const gitCmds = loadCommands(gitModules);
const redisCmds = loadCommands(redisModules);
const dockerCmds = loadCommands(dockerModules);

const domains = [
  { id: 'linux', label: 'Linux', desc: '系统命令', count: linuxCmds.length,
    icon: `<iconify-icon icon="mdi:linux" width="20" height="20"></iconify-icon>` },
  { id: 'cmd', label: 'Windows CMD', desc: '命令提示符', count: cmdCmds.length,
    icon: `<iconify-icon icon="mdi:microsoft-windows" width="20" height="20"></iconify-icon>` },
  { id: 'powershell', label: 'PowerShell', desc: 'PowerShell 命令', count: psCmds.length,
    icon: `<iconify-icon icon="mdi:powershell" width="20" height="20"></iconify-icon>` },
  { id: 'claudecode', label: 'Claude Code', desc: 'AI 编程助手', count: claudeCmds.length,
    icon: `<iconify-icon icon="mdi:code-braces" width="20" height="20"></iconify-icon>` },
  { id: 'npm', label: 'npm', desc: '包管理器', count: npmCmds.length,
    icon: `<iconify-icon icon="mdi:npm" width="20" height="20"></iconify-icon>` },
  { id: 'git', label: 'Git', desc: '版本控制', count: gitCmds.length,
    icon: `<iconify-icon icon="mdi:git" width="20" height="20"></iconify-icon>` },
  { id: 'redis', label: 'Redis', desc: '内存数据库', count: redisCmds.length,
    icon: `<iconify-icon icon="mdi:database" width="20" height="20"></iconify-icon>` },
  { id: 'docker', label: 'Docker', desc: '容器化平台', count: dockerCmds.length,
    icon: `<iconify-icon icon="mdi:docker" width="20" height="20"></iconify-icon>` },
];

const allCommands: Record<string, any[]> = { linux: linuxCmds, cmd: cmdCmds, powershell: psCmds, claudecode: claudeCmds, npm: npmCmds, git: gitCmds, redis: redisCmds, docker: dockerCmds };
---

<Layout title="Cmd Cheatsheet - 命令速查站" description="Linux · Claude Code · Windows · npm · Git · Redis · Docker 常用命令速查">
  {/* ===== Search Modal (inside page for script binding) ===== */}
  <div class="search-overlay" id="search-overlay">
    <div class="search-modal">
      <div class="search-input-wrap">
        <iconify-icon icon="mdi:magnify" width="18" height="18"></iconify-icon>
        <input class="search-input" id="search-input" type="text" placeholder="输入命令名称、描述或标签..." autocomplete="off" />
        <span class="search-kbd-hint" id="search-close-hint">ESC</span>
      </div>
      <div class="search-results" id="search-results">
        <div class="search-empty">输入关键词开始搜索</div>
      </div>
      <div class="search-footer">
        <span><kbd>↑↓</kbd> 导航</span>
        <span><kbd>Enter</kbd> 展开</span>
        <span><kbd>ESC</kbd> 关闭</span>
      </div>
    </div>
  </div>

  {/* Back to top button */}
  <button class="back-to-top" id="back-to-top" aria-label="回到顶部">
    <iconify-icon icon="mdi:chevron-up" width="20" height="20"></iconify-icon>
  </button>

  {/* ===== Body ===== */}
  <div class="body-layout">
    <DomainSidebar domains={domains} />

    <main class="main-area" id="main-area">
      <div class="main-header">
        <div class="main-header-left">
          <h1 class="main-title" id="main-title">
            <span class="title-icon" id="title-icon" set:html={domains[0].icon} />
            <span id="title-text">Linux</span>
          </h1>
          <p class="main-subtitle" id="main-subtitle">共 {linuxCmds.length} 条命令 · 点击展开查看详情</p>
        </div>
        <button class="toggle-all-btn" id="btn-toggle-all" title="一键展开/折叠">
          <iconify-icon class="toggle-icon" icon="mdi:chevron-down" width="18" height="18"></iconify-icon>
        </button>
      </div>
      <div id="accordion-container"></div>
    </main>

    <CommandNav commands={linuxCmds} />
  </div>

  {/* Footer */}
  <footer class="site-footer">
    <span>© 2026 Cmd Cheatsheet · 命令速查站</span>
    <div class="footer-links">
      <a href="https://github.com/why-qw1ko/cmd-cheatsheet" target="_blank" rel="noopener">GitHub</a>
      <a href="https://github.com/why-qw1ko/cmd-cheatsheet/releases" target="_blank" rel="noopener">更新日志</a>
      <a href="https://github.com/why-qw1ko/cmd-cheatsheet/issues" target="_blank" rel="noopener">反馈</a>
    </div>
  </footer>

  <script id="domain-data" type="application/json" set:html={JSON.stringify(allCommands)} />
  <script id="cross-platform-data" type="application/json" set:html={JSON.stringify((await import('../data/cross-platform.json')).default)} />
</Layout>

<script>
  interface Command {
    name: string;
    aliases?: string[];
    domain: string;
    category: string;
    tags?: string[];
    description: string;
    syntax?: string;
    scenarios?: string[];
    related?: string[];
    example?: string;
    variants?: { name: string; syntax: string; example?: string }[];
  }

  const categoryLabels: Record<string, string> = {
    file: '文件', text: '文本', system: '系统', network: '网络',
    process: '进程', session: '会话', config: '配置', review: '审查',
    cli: 'CLI', package: '包管理',
  };
  const categoryClass: Record<string, string> = {
    file: 'cat-file', text: 'cat-text', system: 'cat-system', network: 'cat-network',
    process: 'cat-process', session: 'cat-session', config: 'cat-config', review: 'cat-review',
    cli: 'cat-cli', package: 'cat-package',
  };
  const domainLabels: Record<string, string> = {
    linux: 'Linux', cmd: 'Windows CMD', powershell: 'PowerShell', claudecode: 'Claude Code', npm: 'npm', git: 'Git', redis: 'Redis', docker: 'Docker',
  };
  const platformLabels: Record<string, string> = {
    linux: 'Linux', cmd: 'CMD', powershell: 'PowerShell',
  };

  // Danger levels
  const dangerMap: Record<string, 'high' | 'mid'> = {
    'rm': 'high', 'mkfs': 'high', 'dd': 'high', 'fdisk': 'high',
    'kill': 'high', 'pkill': 'high', 'killall': 'high',
    'shutdown': 'high', 'format': 'high', 'reg': 'mid',
    'chmod': 'mid', 'chown': 'mid', 'sfc': 'mid', 'del': 'mid',
    'taskkill': 'high', 'Stop-Process': 'high',
    'mount': 'mid', 'umount': 'mid', 'Remove-Item': 'mid',
    'FLUSHDB': 'high', 'FLUSHALL': 'high',
  };
  const dangerLabel: Record<string, string> = { high: '高危', mid: '中危' };
  const dangerClass: Record<string, string> = { high: 'danger-high', mid: 'danger-mid' };

  // Expand memory
  let expandMemory = new Set<string>();
  function loadExpandMemory(domain: string) {
    try { expandMemory = new Set(JSON.parse(localStorage.getItem('expand_' + domain) || '[]')); } catch { expandMemory = new Set(); }
  }
  function saveExpandMemory(domain: string) {
    localStorage.setItem('expand_' + domain, JSON.stringify([...expandMemory]));
  }
  function isExpanded(cmdName: string): boolean {
    return expandMemory.has(cmdName);
  }
  const domainIcons: Record<string, string> = {
    linux: `<iconify-icon icon="mdi:linux" width="20" height="20"></iconify-icon>`,
    cmd: `<iconify-icon icon="mdi:microsoft-windows" width="20" height="20"></iconify-icon>`,
    powershell: `<iconify-icon icon="mdi:powershell" width="20" height="20"></iconify-icon>`,
    claudecode: `<iconify-icon icon="mdi:code-braces" width="20" height="20"></iconify-icon>`,
    npm: `<iconify-icon icon="mdi:npm" width="20" height="20"></iconify-icon>`,
    git: `<iconify-icon icon="mdi:git" width="20" height="20"></iconify-icon>`,
    redis: `<iconify-icon icon="mdi:database" width="20" height="20"></iconify-icon>`,
    docker: `<iconify-icon icon="mdi:docker" width="20" height="20"></iconify-icon>`,
  };

  const dataEl = document.getElementById('domain-data');
  const allCommands: Record<string, Command[]> = dataEl ? JSON.parse(dataEl.textContent || '{}') : {};

  // Load cross-platform data
  const cpDataEl = document.getElementById('cross-platform-data');
  const crossPlatformGroups: {group: string; label: string; commands: {name: string; platform: string}[]}[] = cpDataEl ? JSON.parse(cpDataEl.textContent || '[]') : [];
  const cpLookup: Record<string, {label: string; others: {name: string; platform: string}[]}[]> = {};
  crossPlatformGroups.forEach(g => {
    g.commands.forEach(cmd => {
      const key = cmd.name;
      if (!cpLookup[key]) cpLookup[key] = [];
      cpLookup[key].push({ label: g.label, others: g.commands.filter(c => c.name !== cmd.name) });
    });
  });

  // Filter state
  let activeTag: string | null = null;
  let activeCategory: string | null = null;

  function escapeHtml(str: string): string {
    return str.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
  }

  function renderAccordion(commands: Command[], domain: string): string {
    return `<div class="accordion-list" id="accordion-list">${commands.map((cmd, i) => {
      const cat = categoryLabels[cmd.category] || cmd.category;
      const aliasStr = cmd.aliases?.length ? `<span class="accordion-alias">${escapeHtml(cmd.aliases.join(', '))}</span>` : '';
      const tagsHtml = cmd.tags?.length ? `<div class="cmd-tags">${cmd.tags.map(t => `<button class="cmd-tag${activeTag === t ? ' active' : ''}" data-tag="${escapeHtml(t)}">#${escapeHtml(t)}</button>`).join('')}</div>` : '';

      // Cross-platform equivalents
      const cpEntries = cpLookup[cmd.name] || [];
      let cpHtml = '';
      if (cpEntries.length) {
        const entry = cpEntries[0];
        const others = entry.others.filter(o => o.name !== cmd.name);
        if (others.length) {
          const platformSvgIcons: Record<string, string> = {
            linux: '<iconify-icon icon="mdi:linux" width="14" height="14"></iconify-icon>',
            cmd: '<iconify-icon icon="mdi:microsoft-windows" width="14" height="14"></iconify-icon>',
            powershell: '<iconify-icon icon="mdi:powershell" width="14" height="14"></iconify-icon>',
          };
          const items = others.map(o => {
            const icon = platformSvgIcons[o.platform] || '';
            const label = platformLabels[o.platform] || o.platform;
            return `<span class="cp-equiv-item" data-cmd="${escapeHtml(o.name)}" data-platform="${o.platform}">${icon} <code>${escapeHtml(o.name)}</code> <small>${label}</small></span>`;
          }).join('');
          cpHtml = `<div class="cmd-cross-platform"><div class="cmd-label">🔄 跨平台对照</div><div class="cp-equiv-list">${items}</div></div>`;
        }
      }

      let syntaxHtml = '';
      if (cmd.variants?.length) {
        const tabs = cmd.variants.map((v, vi) => `<button class="variant-tab${vi === 0 ? ' active' : ''}" data-tab="${cmd.name}-v-${vi}">${escapeHtml(v.name)}</button>`).join('');
        const panels = cmd.variants.map((v, vi) => `<div class="variant-panel${vi === 0 ? ' active' : ''}" data-panel="${cmd.name}-v-${vi}"><div class="cmd-syntax-block"><div><div class="cmd-label">语法</div><code>${escapeHtml(v.syntax)}</code></div><button class="copy-btn" data-copy="${escapeHtml(v.syntax)}">📋 复制</button></div>${v.example ? `<div class="cmd-example-block"><div class="cmd-label">示例</div><code>${escapeHtml(v.example)}</code></div>` : ''}</div>`).join('');
        syntaxHtml = `<div class="variant-tabs" role="tablist">${tabs}</div>${panels}`;
      } else {
        syntaxHtml = (cmd.syntax ? `<div class="cmd-syntax-block"><div><div class="cmd-label">语法</div><code>${escapeHtml(cmd.syntax)}</code></div><button class="copy-btn" data-copy="${escapeHtml(cmd.syntax)}">📋 复制</button></div>` : '') + (cmd.example ? `<div class="cmd-example-block"><div class="cmd-label">示例</div><code>${escapeHtml(cmd.example)}</code></div>` : '');
      }

      const scenariosHtml = cmd.scenarios?.length ? `<div class="cmd-scenarios"><div class="cmd-label">🎯 使用场景</div><ul>${cmd.scenarios.map(s => `<li>${escapeHtml(s)}</li>`).join('')}</ul></div>` : '';
      const relatedHtml = cmd.related?.length ? `<div class="cmd-related"><span class="cmd-label">相关:</span>${cmd.related.map(r => `<span class="cmd-alias-tag">${escapeHtml(r)}</span>`).join('')}</div>` : '';

      const danger = dangerMap[cmd.name];
      const dangerBadge = danger ? `<span class="accordion-danger ${dangerClass[danger]}">${dangerLabel[danger]}</span>` : '';
      const expanded = isExpanded(cmd.name);
      return `<div class="accordion-item${expanded ? ' open' : ''}" id="cmd-${cmd.name}" data-index="${i}">
        <div class="accordion-header" role="button" tabindex="0">
          <div class="accordion-title">
            <span class="accordion-name">${escapeHtml(cmd.name)}</span>
            ${dangerBadge}
            <button class="accordion-cat ${categoryClass[cmd.category] || ""}" data-category="${escapeHtml(cmd.category)}">${escapeHtml(cat)}</button>
            ${aliasStr}
          </div>
          <div class="accordion-right">
            <button class="header-copy-btn" data-copy="${escapeHtml(cmd.name)}" title="复制命令名">
              <iconify-icon icon="mdi:content-copy" width="14" height="14"></iconify-icon>
            </button>
            <iconify-icon class="accordion-chevron" icon="mdi:chevron-down" width="18" height="18"></iconify-icon>
          </div>
        </div>
        <div class="accordion-body"><div class="accordion-content"><div class="accordion-content-inner">
          ${tagsHtml}<p class="cmd-desc">${escapeHtml(cmd.description)}</p>${syntaxHtml}${scenariosHtml}${cpHtml}${relatedHtml}
        </div></div></div>
      </div>`;
    }).join('')}</div>`;
  }

  function renderNav(commands: Command[]) {
    const navList = document.getElementById('nav-list');
    if (!navList) return;
    // Group by first letter
    const groups: Record<string, Command[]> = {};
    commands.forEach(cmd => {
      const letter = (cmd.name.replace(/^[^a-zA-Z]*/, '') || cmd.name)[0]?.toUpperCase() || '#';
      if (!groups[letter]) groups[letter] = [];
      groups[letter].push(cmd);
    });
    const letters = Object.keys(groups).sort();
    let html = '';
    letters.forEach(letter => {
      html += `<div class="nav-letter-group" data-letter="${letter}"><div class="nav-letter">${letter}</div>`;
      groups[letter].forEach(cmd => {
        html += `<a class="floating-nav-link" href="#cmd-${cmd.name}" data-target="${cmd.name}" data-letter="${letter}"><span>${escapeHtml(cmd.name)}</span></a>`;
      });
      html += `</div>`;
    });
    navList.innerHTML = html;
    // Update letter index
    const indexEl = document.getElementById('nav-letter-index');
    if (indexEl) {
      indexEl.innerHTML = letters.map(l => `<button class="letter-btn" data-letter="${l}">${l}</button>`).join('');
    }
    // Reset letter filter
    const activeBtn = indexEl?.querySelector('.letter-btn.active');
    if (activeBtn) activeBtn.classList.remove('active');
  }

  // Tag filter re-render
  function reRenderAccordion(domain: string) {
    let commands = allCommands[domain] || [];
    if (activeTag) {
      commands = commands.filter(cmd => cmd.tags?.includes(activeTag!));
    }
    if (activeCategory) {
      commands = commands.filter(cmd => cmd.category === activeCategory);
    }
    if (container) container.innerHTML = renderAccordion(commands, domain);
    renderNav(commands);
    updateFilterBar();
    requestAnimationFrame(() => { if ((window as any).initScrollSpy) (window as any).initScrollSpy(); });
  }

  function updateFilterBar() {
    const existing = document.getElementById('tag-filter-bar');
    if (existing) existing.remove();
    if (!activeTag && !activeCategory) return;
    const mainHeader = document.querySelector('.main-header');
    if (!mainHeader) return;
    const bar = document.createElement('div');
    bar.id = 'tag-filter-bar';
    bar.className = 'tag-filter-bar';
    let parts = [];
    if (activeCategory) parts.push(`<span class="tag-filter-tag cat">${escapeHtml(categoryLabels[activeCategory] || activeCategory)}</span>`);
    if (activeTag) parts.push(`<span class="tag-filter-tag">#${escapeHtml(activeTag)}</span>`);
    bar.innerHTML = `<span class="tag-filter-label">筛选:</span>${parts.join('')}<button class="tag-filter-clear" id="tag-filter-clear">✕ 清除</button>`;
    mainHeader.insertAdjacentElement('afterend', bar);
    document.getElementById('tag-filter-clear')?.addEventListener('click', () => {
      activeTag = null;
      activeCategory = null;
      const currentDomain = (document.querySelector('.sidebar-btn.active') as HTMLElement)?.dataset?.domain || 'linux';
      reRenderAccordion(currentDomain);
    });
  }

  // Cross-platform view
  function renderCrossPlatformView() {
    const container = document.getElementById('accordion-container');
    if (!container) return;
    const platformSvgIcons: Record<string, string> = {
      linux: '<iconify-icon icon="mdi:linux" width="16" height="16"></iconify-icon>',
      cmd: '<iconify-icon icon="mdi:microsoft-windows" width="16" height="16"></iconify-icon>',
      powershell: '<iconify-icon icon="mdi:powershell" width="16" height="16"></iconify-icon>',
    };
    const html = crossPlatformGroups.map(g => {
      const items = g.commands.map(c => {
        const icon = platformSvgIcons[c.platform] || '';
        return `<span class="cp-view-item" data-cmd="${escapeHtml(c.name)}" data-platform="${c.platform}">${icon} <code>${escapeHtml(c.name)}</code></span>`;
      }).join('');
      return `<div class="cp-view-group"><div class="cp-view-label">${escapeHtml(g.label)}</div><div class="cp-view-items">${items}</div></div>`;
    }).join('');
    container.innerHTML = `<div class="cp-view-list">${html}</div>`;
    // Hide nav
    const nav = document.getElementById('floating-nav') as HTMLElement;
    if (nav) nav.style.display = 'none';
  }

  // Initial render — check URL param for domain
  const container = document.getElementById('accordion-container');
  const urlDomain = new URLSearchParams(window.location.search).get('domain');
  const initialDomain = (urlDomain && allCommands[urlDomain]) ? urlDomain : 'linux';
  if (container) container.innerHTML = renderAccordion(allCommands[initialDomain] || [], initialDomain);
  renderNav(allCommands[initialDomain] || []);
  loadExpandMemory(initialDomain);
  // Update sidebar active state if not default
  if (initialDomain !== 'linux') {
    document.querySelectorAll('.sidebar-btn[data-domain]').forEach(btn => {
      btn.classList.toggle('active', (btn as HTMLElement).dataset.domain === initialDomain);
    });
    const titleIcon = document.getElementById('title-icon');
    const titleText = document.getElementById('title-text');
    const subtitle = document.getElementById('main-subtitle');
    if (titleIcon) titleIcon.innerHTML = domainIcons[initialDomain] || '';
    if (titleText) titleText.textContent = domainLabels[initialDomain] || initialDomain;
    if (subtitle) subtitle.textContent = `共 ${(allCommands[initialDomain] || []).length} 条命令 · 点击展开查看详情`;
  }
  requestAnimationFrame(() => { if ((window as any).initScrollSpy) (window as any).initScrollSpy(); });

  // Domain switch
  function switchDomain(domain: string) {
    const commands = allCommands[domain];
    if (!commands) return;
    loadExpandMemory(domain);
    activeTag = null;
    activeCategory = null;

    document.querySelectorAll('.sidebar-btn[data-domain]').forEach(btn => {
      btn.classList.toggle('active', (btn as HTMLElement).dataset.domain === domain);
    });
    document.getElementById('btn-cross-platform')?.classList.remove('active');

    const titleIcon = document.getElementById('title-icon');
    const titleText = document.getElementById('title-text');
    const subtitle = document.getElementById('main-subtitle');
    const mobileTitle = document.getElementById('mobile-topbar-title');
    if (titleIcon) titleIcon.innerHTML = domainIcons[domain] || '';
    if (titleText) titleText.textContent = domainLabels[domain] || domain;
    if (subtitle) subtitle.textContent = `共 ${commands.length} 条命令 · 点击展开查看详情`;
    if (mobileTitle) mobileTitle.textContent = domainLabels[domain] || domain;

    if (container) {
      // Show skeleton briefly
      container.innerHTML = Array(8).fill('<div class="skeleton-item"></div>').join('');
      // Restore nav visibility
      const nav = document.getElementById('floating-nav') as HTMLElement;
      if (nav) nav.style.display = '';
      // Remove filter bar
      const filterBar = document.getElementById('tag-filter-bar');
      if (filterBar) filterBar.remove();
      requestAnimationFrame(() => {
        setTimeout(() => {
          container.innerHTML = renderAccordion(commands, domain);
          renderNav(commands);
          requestAnimationFrame(() => { if ((window as any).initScrollSpy) (window as any).initScrollSpy(); });
        }, 150);
      });
    }
    window.scrollTo({ top: 0, behavior: 'smooth' });
    document.dispatchEvent(new CustomEvent('domain-changed'));
    document.dispatchEvent(new CustomEvent('domain-switched'));  
  }

  // Sidebar click
  document.getElementById('domain-sidebar')?.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest('.sidebar-btn[data-domain]') as HTMLElement;
    if (btn?.dataset.domain) switchDomain(btn.dataset.domain);
  });

  // Cross-platform button
  document.getElementById('btn-cross-platform')?.addEventListener('click', () => {
    // Highlight the button
    document.querySelectorAll('.sidebar-btn[data-domain]').forEach(b => b.classList.remove('active'));
    document.getElementById('btn-cross-platform')?.classList.add('active');
    // Update title
    const titleIcon = document.getElementById('title-icon');
    const titleText = document.getElementById('title-text');
    const subtitle = document.getElementById('main-subtitle');
    if (titleIcon) titleIcon.innerHTML = `<iconify-icon icon="mdi:swap-horizontal" width="20" height="20"></iconify-icon>`;
    if (titleText) titleText.textContent = '跨平台对照';
    if (subtitle) subtitle.textContent = `共 ${crossPlatformGroups.length} 组对照 · 点击命令可跳转`;
    // Render
    activeTag = null;
    renderCrossPlatformView();
    window.scrollTo({ top: 0, behavior: 'smooth' });
  });

  // Cross-platform item click -> jump to command
  document.getElementById('accordion-container')?.addEventListener('click', (e) => {
    const item = (e.target as HTMLElement).closest('.cp-view-item, .cp-equiv-item') as HTMLElement;
    if (!item) return;
    const cmdName = item.dataset.cmd;
    const platform = item.dataset.platform;
    if (!cmdName) return;
    // Find which domain this command belongs to
    const domain = platform === 'linux' ? 'linux' : platform === 'powershell' ? 'powershell' : 'cmd';
    switchDomain(domain);
    setTimeout(() => {
      const el = document.getElementById(`cmd-${cmdName}`);
      if (el) {
        if (!el.classList.contains('open')) el.classList.add('open');
        const h = el.querySelector('.accordion-header');
        if (h) { const r = h.getBoundingClientRect(); window.scrollTo({ top: window.scrollY + r.top - 62, behavior: 'smooth' }); }
      }
    }, 300);
  });

  // Update header stat badge (header is in Layout, outside page-content)
  const statBadge = document.getElementById('header-stat-badge');
  if (statBadge) statBadge.textContent = Object.values(allCommands).reduce((s, cmds) => s + cmds.length, 0) + ' 条命令';

  // Accordion + copy (event delegation on container)
  document.getElementById('accordion-container')?.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;

    // Tag click -> filter
    const tagBtn = target.closest('.cmd-tag');
    if (tagBtn) {
      e.stopPropagation();
      const tag = (tagBtn as HTMLElement).dataset.tag;
      if (tag) {
        activeTag = activeTag === tag ? null : tag;
        const currentDomain = (document.querySelector('.sidebar-btn.active') as HTMLElement)?.dataset?.domain || 'linux';
        reRenderAccordion(currentDomain);
      }
      return;
    }

    // Category click -> filter
    const catBtn = target.closest('.accordion-cat');
    if (catBtn) {
      e.stopPropagation();
      const cat = (catBtn as HTMLElement).dataset.category;
      if (cat) {
        activeCategory = activeCategory === cat ? null : cat;
        const currentDomain = (document.querySelector('.sidebar-btn.active') as HTMLElement)?.dataset?.domain || 'linux';
        reRenderAccordion(currentDomain);
      }
      return;
    }

    // Skip if clicking header-copy-btn (handled by separate handler)
    if (target.closest('.header-copy-btn')) return;

    // Copy button
    const copyBtn = target.closest('.copy-btn');
    if (copyBtn) {
      e.stopPropagation();
      const text = copyBtn.getAttribute('data-copy');
      if (text) {
        navigator.clipboard.writeText(text).then(() => {
          copyBtn.textContent = '✅ 已复制';
          setTimeout(() => { copyBtn.textContent = '📋 复制'; }, 2000);
        });
      }
      return;
    }

    // Variant tab
    const variantTab = target.closest('.variant-tab');
    if (variantTab) {
      e.stopPropagation();
      const tabId = (variantTab as HTMLElement).dataset.tab;
      if (!tabId) return;
      const item = (variantTab as HTMLElement).closest('.accordion-item');
      if (!item) return;
      item.querySelectorAll('.variant-tab').forEach(t => t.classList.remove('active'));
      item.querySelectorAll('.variant-panel').forEach(p => p.classList.remove('active'));
      variantTab.classList.add('active');
      item.querySelector(`[data-panel="${tabId}"]`)?.classList.add('active');
      return;
    }

    // Accordion toggle
    const header = target.closest('.accordion-header');
    if (header) {
      const item = header.closest('.accordion-item');
      if (item) {
        item.classList.toggle('open');
        const name = item.id.replace('cmd-', '');
        if (item.classList.contains('open')) expandMemory.add(name);
        else expandMemory.delete(name);
        const currentDomain = (document.querySelector('.sidebar-btn.active') as HTMLElement)?.dataset?.domain || 'linux';
        saveExpandMemory(currentDomain);
      }
    }
  });

  // Nav click (event delegation)
  document.getElementById('floating-nav')?.addEventListener('click', (e) => {
    const link = (e.target as HTMLElement).closest('.floating-nav-link') as HTMLAnchorElement;
    if (!link) return;
    e.preventDefault();
    const targetName = link.dataset.target;
    const activeLetterBtn = document.querySelector('.letter-btn.active');
    let el: HTMLElement | null = null;
    if (activeLetterBtn) {
      // Letter filter active - only look in visible group
      const activeGroup = document.querySelector('.nav-letter-group:not(.hidden)');
      el = activeGroup?.querySelector(`[data-target="${targetName}"]`) as HTMLElement | null;
    } else {
      el = document.getElementById(`cmd-${targetName}`);
    }
    if (el) {
      if (!el.classList.contains('open')) el.classList.add('open');
      const header = el.querySelector('.accordion-header');
      if (header) {
        const rect = header.getBoundingClientRect();
        window.scrollTo({ top: window.scrollY + rect.top - 62, behavior: 'smooth' });
      }
    }
  });

  // Search trigger
  const searchOverlay = document.getElementById('search-overlay');
  const searchInput = document.getElementById('search-input') as HTMLInputElement;
  const searchResults = document.getElementById('search-results');

  // Build search index
  interface SearchItem {
    name: string;
    domain: string;
    category: string;
    description: string;
    tags: string[];
    aliases: string[];
    searchText: string;
  }

  const searchIndex: SearchItem[] = [];
  const domainLabelMap: Record<string, string> = { linux: 'Linux', claudecode: 'Claude Code', cmd: 'Windows CMD', powershell: 'PowerShell', npm: 'npm', git: 'Git', redis: 'Redis', docker: 'Docker' };

  for (const [domain, cmds] of Object.entries(allCommands)) {
    for (const cmd of cmds) {
      searchIndex.push({
        name: cmd.name,
        domain,
        category: categoryLabels[cmd.category] || cmd.category,
        description: cmd.description,
        tags: cmd.tags || [],
        aliases: cmd.aliases || [],
        searchText: [cmd.name, ...(cmd.aliases || []), cmd.description, cmd.category, ...(cmd.tags || [])].join(' ').toLowerCase(),
      });
    }
  }

  let searchActiveIdx = -1;

  function openSearch() {
    searchOverlay?.classList.add('open');
    searchInput?.focus();
    searchInput.value = '';
    renderSearchResults('');
  }

  function closeSearch() {
    searchOverlay?.classList.remove('open');
    searchActiveIdx = -1;
  }

  function renderSearchResults(query: string) {
    if (!searchResults) return;
    if (!query.trim()) {
      searchResults.innerHTML = '<div class="search-empty">输入关键词开始搜索</div>';
      return;
    }
    const q = query.toLowerCase();
    const matches = searchIndex.filter(item => item.searchText.includes(q)).slice(0, 20);
    if (!matches.length) {
      searchResults.innerHTML = `<div class="search-empty">未找到 "${escapeHtml(query)}" 相关命令</div>`;
      return;
    }
    searchActiveIdx = 0;
    searchResults.innerHTML = matches.map((item, i) => `
      <div class="search-result-item${i === 0 ? ' active' : ''}" data-domain="${item.domain}" data-name="${item.name}">
        <div class="search-result-info">
          <div style="display:flex;align-items:center;gap:8px;">
            <span class="search-result-name">${escapeHtml(item.name)}</span>
            <span class="search-result-cat">${escapeHtml(item.category)}</span>
            <span class="search-result-domain">${escapeHtml(domainLabelMap[item.domain] || item.domain)}</span>
          </div>
          <div class="search-result-desc">${escapeHtml(item.description)}</div>
        </div>
      </div>
    `).join('');
  }

  function navigateSearchResult(delta: number) {
    const items = searchResults?.querySelectorAll('.search-result-item');
    if (!items?.length) return;
    items[searchActiveIdx]?.classList.remove('active');
    searchActiveIdx = Math.max(0, Math.min(items.length - 1, searchActiveIdx + delta));
    items[searchActiveIdx]?.classList.add('active');
    items[searchActiveIdx]?.scrollIntoView({ block: 'nearest' });
  }

  function selectSearchResult() {
    const items = searchResults?.querySelectorAll('.search-result-item');
    const active = items?.[searchActiveIdx] as HTMLElement;
    if (!active) return;
    const domain = active.dataset.domain;
    const name = active.dataset.name;
    const currentDomain = (document.querySelector('.sidebar-btn.active') as HTMLElement)?.dataset?.domain || 'linux';
    const needSwitch = domain && domain !== currentDomain;
    if (needSwitch) switchDomain(domain);
    closeSearch();
    // Wait longer if switching domain (needs time for accordion re-render)
    const delay = needSwitch ? 300 : 50;
    setTimeout(() => {
      const el = document.getElementById(`cmd-${name}`);
      if (el) {
        if (!el.classList.contains('open')) el.classList.add('open');
        const h = el.querySelector('.accordion-header');
        if (h) { const r = h.getBoundingClientRect(); window.scrollTo({ top: window.scrollY + r.top - 62, behavior: 'smooth' }); }
      }
    }, delay);
  }

  // Search event handlers
  const _sig = (window as any).__pageAbort?.signal;

  document.getElementById('search-trigger')?.addEventListener('click', openSearch, { signal: _sig });
  document.getElementById('search-close-hint')?.addEventListener('click', closeSearch);
  searchOverlay?.addEventListener('click', (e) => {
    if (e.target === searchOverlay) closeSearch();
  });

  searchInput?.addEventListener('input', (e) => {
    renderSearchResults((e.target as HTMLInputElement).value);
  });

  searchInput?.addEventListener('keydown', (e) => {
    if (e.key === 'ArrowDown') { e.preventDefault(); navigateSearchResult(1); }
    else if (e.key === 'ArrowUp') { e.preventDefault(); navigateSearchResult(-1); }
    else if (e.key === 'Enter') { e.preventDefault(); selectSearchResult(); }
    else if (e.key === 'Escape') { closeSearch(); }
  });

  searchResults?.addEventListener('click', (e) => {
    const item = (e.target as HTMLElement).closest('.search-result-item') as HTMLElement;
    if (!item) return;
    const domain = item.dataset.domain;
    const name = item.dataset.name;
    const currentDomain = (document.querySelector('.sidebar-btn.active') as HTMLElement)?.dataset?.domain || 'linux';
    const needSwitch = domain && domain !== currentDomain;
    if (needSwitch) switchDomain(domain);
    closeSearch();
    const delay = needSwitch ? 300 : 50;
    setTimeout(() => {
      const el = document.getElementById(`cmd-${name}`);
      if (el) {
        if (!el.classList.contains('open')) el.classList.add('open');
        const h = el.querySelector('.accordion-header');
        if (h) { const r = h.getBoundingClientRect(); window.scrollTo({ top: window.scrollY + r.top - 62, behavior: 'smooth' }); }
      }
    }, delay);
  });

  // Ctrl+K shortcut
  document.addEventListener('keydown', (e) => {
    if ((e.ctrlKey || e.metaKey) && e.key === 'k') {
      e.preventDefault();
      openSearch();
    }
    if (e.key === 'Escape' && searchOverlay?.classList.contains('open')) {
      closeSearch();
    }
  }, { signal: _sig });

  // Back to top button
  const backToTopBtn = document.getElementById('back-to-top');

  // Avatar click -> toast
  document.getElementById('sidebar-avatar-btn')?.addEventListener('click', () => {
    const existing = document.querySelector('.dev-toast');
    if (existing) existing.remove();
    const toast = document.createElement('div');
    toast.className = 'dev-toast';
    toast.textContent = '🚧 功能开发中，敬请期待';
    document.body.appendChild(toast);
    requestAnimationFrame(() => toast.classList.add('show'));
    setTimeout(() => { toast.classList.remove('show'); setTimeout(() => toast.remove(), 300); }, 2000);
  });
  window.addEventListener('scroll', () => {
    if (window.scrollY > 300) {
      backToTopBtn?.classList.add('visible');
    } else {
      backToTopBtn?.classList.remove('visible');
    }
  });
  backToTopBtn?.addEventListener('click', () => {
    window.scrollTo({ top: 0, behavior: 'smooth' });
  });

  // Toggle All (single button)
  let allExpanded = false;
  document.getElementById('btn-toggle-all')?.addEventListener('click', () => {
    allExpanded = !allExpanded;
    document.querySelectorAll('.accordion-item').forEach(item => {
      const name = item.id.replace('cmd-', '');
      if (allExpanded) { item.classList.add('open'); expandMemory.add(name); }
      else { item.classList.remove('open'); expandMemory.delete(name); }
    });
    const currentDomain = (document.querySelector('.sidebar-btn.active') as HTMLElement)?.dataset?.domain || 'linux';
    saveExpandMemory(currentDomain);
    // Rotate arrow icon
    const icon = document.querySelector('.toggle-icon');
    if (icon) (icon as HTMLElement).style.transform = allExpanded ? 'rotate(180deg)' : '';
  });

  // Header copy button (inside accordion header)
  function showCopyToast() {
    const existing = document.querySelector('.copy-toast');
    if (existing) existing.remove();
    const toast = document.createElement('div');
    toast.className = 'copy-toast';
    toast.innerHTML = '<iconify-icon icon="mdi:check-circle" width="16" height="16" style="color:#22c55e"></iconify-icon> 复制成功';
    document.body.appendChild(toast);
    requestAnimationFrame(() => toast.classList.add('show'));
    setTimeout(() => { toast.classList.remove('show'); setTimeout(() => toast.remove(), 200); }, 1000);
  }

  document.getElementById('accordion-container')?.addEventListener('click', (e) => {
    const copyBtn = (e.target as HTMLElement).closest('.header-copy-btn');
    if (copyBtn) {
      e.stopPropagation();
      e.preventDefault();
      const text = copyBtn.getAttribute('data-copy');
      if (text) {
        navigator.clipboard.writeText(text).then(() => {
          showCopyToast();
          const icon = copyBtn.querySelector('iconify-icon');
          if (icon) {
            icon.setAttribute('icon', 'mdi:check-circle');
            icon.style.color = '#22c55e';
          }
          setTimeout(() => {
            const icon2 = copyBtn.querySelector('iconify-icon');
            if (icon2) {
              icon2.setAttribute('icon', 'mdi:content-copy');
              icon2.style.color = '';
            }
          }, 1500);
        });
      }
    }
  });
</script>
