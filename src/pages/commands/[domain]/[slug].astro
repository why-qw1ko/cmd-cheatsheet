---
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';
import CommandCard from '../../../components/CommandCard.astro';

export async function getStaticPaths() {
  const domains = ['linux', 'claudecode', 'windows'];
  const paths: any[] = [];

  for (const domain of domains) {
    // Import all JSON files from this domain
    const modules = import.meta.glob('../../../data/commands/*/*.json', { eager: true });

    for (const [path, mod] of Object.entries(modules)) {
      // Skip _meta.json
      if (path.includes('_meta.json')) continue;

      const data = (mod as any).default || mod;
      // Check if this file belongs to current domain
      if (!path.includes(`/commands/${domain}/`)) continue;

      const slug = path.split('/').pop()?.replace('.json', '') || '';

      // Build related links
      const relatedLinks: Record<string, string> = {};
      if (data.related) {
        data.related.forEach((r: string) => {
          const relSlug = r.replace(/^\//, '').toLowerCase().replace(/\s+/g, '-');
          relatedLinks[r] = `/cmd-cheatsheet/commands/${domain}/${relSlug}`;
        });
      }

      paths.push({
        params: { domain, slug },
        props: { data, domain, relatedLinks },
      });
    }
  }

  return paths;
}

const { data, domain, relatedLinks } = Astro.props;
const domainLabels: Record<string, string> = {
  linux: 'Linux',
  claudecode: 'Claude Code',
  windows: 'Windows',
};

const title = `${data.name} — ${domainLabels[domain] || domain}`;
const description = data.description;
---

<StarlightPage frontmatter={{ title, description }}>
  <CommandCard {...data} domain={domain} relatedLinks={relatedLinks} />
  <div style="margin-top: 2rem;">
    <a href="/cmd-cheatsheet/" style="font-size: 0.875rem; opacity: 0.6;">← 返回首页</a>
  </div>
</StarlightPage>
