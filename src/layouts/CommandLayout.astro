---
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';
import CommandCard from '../components/CommandCard.astro';

interface Props {
  frontmatter: {
    title: string;
    description: string;
  };
  data: any;
  domain: string;
}

const { frontmatter, data, domain } = Astro.props;

// Build related links mapping: command name -> URL
function buildRelatedLinks(related: string[], domain: string): Record<string, string> {
  const links: Record<string, string> = {};
  const base = '/cmd-cheatsheet/commands';
  related.forEach((r) => {
    const slug = r.replace(/^\//, '').toLowerCase().replace(/\s+/g, '-');
    links[r] = `${base}/${domain}/${slug}`;
  });
  return links;
}

const relatedLinks = data.related ? buildRelatedLinks(data.related, domain) : {};
---

<StarlightPage frontmatter={{ title: frontmatter.title, description: frontmatter.description }}>
  <CommandCard {...data} domain={domain} relatedLinks={relatedLinks} />
</StarlightPage>
