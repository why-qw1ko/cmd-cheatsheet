---
interface Props {
  title?: string;
  description?: string;
}
const { title = 'Cmd Cheatsheet', description = '命令速查站' } = Astro.props;
---
<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="icon" type="image/svg+xml" href="/cmd-cheatsheet/favicon.svg" />
  <slot name="head" />
</head>
<body>
  <div class="app-shell">
    <slot />
  </div>
</body>
</html>

<style is:global>
  @import "tailwindcss";

  :root {
    --sidebar-w: 220px;
    --accent: #6366f1;
    --accent-light: #818cf8;
    --bg: #f8fafc;
    --bg-card: #ffffff;
    --bg-code: #f1f5f9;
    --border: #e2e8f0;
    --text: #1e293b;
    --text-muted: #64748b;
    --tag-bg: #eef2ff;
    --tag-text: #4f46e5;
    --header-h: 56px;
  }

  [data-theme="dark"] {
    --bg: #0f172a;
    --bg-card: #1e293b;
    --bg-code: #0f172a;
    --border: #334155;
    --text: #f1f5f9;
    --text-muted: #94a3b8;
    --tag-bg: #1e1b4b;
    --tag-text: #a5b4fc;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  html {
    scroll-behavior: smooth;
    background: var(--bg);
    color: var(--text);
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Noto Sans SC', sans-serif;
  }

  body {
    min-height: 100vh;
    overflow-x: hidden;
  }

  .app-shell {
    display: flex;
    flex-direction: column;
    min-height: 100vh;
  }

  /* ==================== Header ==================== */
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: var(--header-h);
    background: var(--bg-card);
    border-bottom: 1px solid var(--border);
    z-index: 300;
    display: flex;
    align-items: center;
    padding: 0 24px;
    gap: 16px;
  }

  .header-left {
    display: flex;
    align-items: center;
    gap: 12px;
    min-width: 200px;
  }

  .header-logo {
    display: flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    color: var(--text);
  }

  .header-logo-icon {
    display: flex;
    align-items: center;
    color: var(--accent);
  }

  .header-logo-text {
    font-size: 1.05rem;
    font-weight: 700;
    white-space: nowrap;
  }

  .header-search {
    flex: 1;
    max-width: 480px;
    position: relative;
  }

  .header-search-btn {
    width: 100%;
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 7px 14px;
    border: 1px solid var(--border);
    border-radius: 8px;
    background: var(--bg);
    cursor: pointer;
    transition: border-color 0.15s;
    color: var(--text-muted);
    font-size: 0.875rem;
  }

  .header-search-btn:hover {
    border-color: var(--accent-light);
  }

  .header-search-btn svg {
    flex-shrink: 0;
    opacity: 0.5;
  }

  .header-search-kbd {
    margin-left: auto;
    font-size: 0.72rem;
    padding: 2px 6px;
    border-radius: 4px;
    border: 1px solid var(--border);
    background: var(--bg-card);
    color: var(--text-muted);
    font-family: inherit;
  }

  .header-right {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-left: auto;
  }

  .header-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border: none;
    background: transparent;
    border-radius: 8px;
    cursor: pointer;
    color: var(--text-muted);
    transition: all 0.15s;
    text-decoration: none;
  }

  .header-btn:hover {
    background: var(--bg-code);
    color: var(--text);
  }

  .header-github-link {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 6px 12px;
    border: 1px solid var(--border);
    border-radius: 8px;
    background: transparent;
    text-decoration: none;
    color: var(--text-muted);
    font-size: 0.8rem;
    font-weight: 500;
    transition: all 0.15s;
    white-space: nowrap;
  }

  .header-github-link:hover {
    border-color: var(--accent-light);
    color: var(--text);
  }

  .header-link {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 6px 12px;
    border-radius: 8px;
    background: transparent;
    text-decoration: none;
    color: var(--text-muted);
    font-size: 0.8rem;
    font-weight: 500;
    transition: all 0.15s;
    white-space: nowrap;
    border: none;
    cursor: pointer;
  }

  .header-link:hover {
    background: var(--bg-code);
    color: var(--text);
  }

  .header-stat-badge {
    font-size: 0.72rem;
    padding: 4px 10px;
    border-radius: 9999px;
    background: var(--tag-bg);
    color: var(--tag-text);
    font-weight: 600;
    white-space: nowrap;
  }

  /* Theme toggle icons */
  .theme-icon-dark { display: none; }
  [data-theme="dark"] .theme-icon-light { display: none; }
  [data-theme="dark"] .theme-icon-dark { display: flex; }

  /* ==================== Body Layout ==================== */
  .body-layout {
    display: flex;
    margin-top: var(--header-h);
    min-height: calc(100vh - var(--header-h));
  }

  /* ==================== Sidebar ==================== */
  .domain-sidebar {
    width: var(--sidebar-w);
    min-width: var(--sidebar-w);
    height: calc(100vh - var(--header-h));
    position: fixed;
    left: 0;
    top: var(--header-h);
    display: flex;
    flex-direction: column;
    background: var(--bg-card);
    border-right: 1px solid var(--border);
    z-index: 100;
    overflow-y: auto;
    padding: 16px 12px;
  }

  .sidebar-section-title {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-muted);
    padding: 8px 10px 6px;
  }

  .sidebar-nav {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .sidebar-btn {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 12px;
    border: none;
    background: transparent;
    border-radius: 10px;
    cursor: pointer;
    transition: all 0.15s;
    color: var(--text-muted);
    text-align: left;
    width: 100%;
  }

  .sidebar-btn:hover {
    background: var(--bg-code);
    color: var(--text);
  }

  .sidebar-btn.active {
    background: var(--tag-bg);
    color: var(--accent);
  }

  .sidebar-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 10px;
    background: var(--bg-code);
    flex-shrink: 0;
    transition: background 0.15s;
  }

  .sidebar-btn.active .sidebar-icon {
    background: rgba(109, 40, 217, 0.15);
  }

  .sidebar-icon svg {
    width: 20px;
    height: 20px;
  }

  .sidebar-btn-text {
    display: flex;
    flex-direction: column;
    min-width: 0;
  }

  .sidebar-btn-label {
    font-size: 0.88rem;
    font-weight: 600;
    line-height: 1.3;
  }

  .sidebar-btn-count {
    font-size: 0.72rem;
    opacity: 0.6;
  }

  .sidebar-divider {
    height: 1px;
    background: var(--border);
    margin: 12px 10px;
  }

  .sidebar-footer {
    margin-top: auto;
    padding-top: 8px;
    border-top: 1px solid var(--border);
  }

  .sidebar-footer .sidebar-btn {
    padding: 8px 12px;
  }

  /* ==================== Main Content ==================== */
  .main-area {
    flex: 1;
    margin-left: var(--sidebar-w);
    margin-right: 280px;
    padding: 32px 48px 80px;
    min-width: 0;
    max-width: 1000px;
  }

  .toggle-all-btn {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    border: 1px solid var(--border);
    background: var(--bg-card);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--text-muted);
    transition: all 0.2s;
    flex-shrink: 0;
  }

  .toggle-all-btn:hover {
    border-color: var(--accent);
    color: var(--accent);
    background: var(--tag-bg);
  }

  .toggle-icon {
    transition: transform 0.3s ease;
  }

  /* Danger badges */
  .accordion-danger {
    font-size: 0.65rem;
    padding: 1px 6px;
    border-radius: 9999px;
    font-weight: 700;
    letter-spacing: 0.03em;
    flex-shrink: 0;
  }

  .danger-high {
    background: #fef2f2;
    color: #dc2626;
  }

  .danger-mid {
    background: #fffbeb;
    color: #d97706;
  }

  [data-theme="dark"] .danger-high {
    background: #450a0a;
    color: #f87171;
  }

  [data-theme="dark"] .danger-mid {
    background: #451a03;
    color: #fbbf24;
  }

  /* Letter index */
  .nav-letter-index {
    display: flex;
    flex-wrap: wrap;
    gap: 2px;
    padding: 8px 12px 4px;
    border-bottom: 1px solid var(--border);
  }

  .letter-btn {
    width: 22px;
    height: 22px;
    display: flex;
    align-items: center;
    justify-content: center;
    border: none;
    background: transparent;
    border-radius: 4px;
    cursor: pointer;
    font-size: 0.7rem;
    font-weight: 600;
    color: var(--text-muted);
    transition: all 0.1s;
  }

  .letter-btn:hover {
    background: var(--tag-bg);
    color: var(--accent);
  }

  .letter-btn.active {
    background: var(--accent);
    color: #fff;
  }

  .nav-letter {
    font-size: 0.7rem;
    font-weight: 700;
    color: var(--text-muted);
    padding: 8px 10px 2px;
    letter-spacing: 0.04em;
  }

  /* Nav scrollbar */
  .floating-nav-list::-webkit-scrollbar {
    width: 4px;
  }

  .floating-nav-list::-webkit-scrollbar-track {
    background: transparent;
  }

  .floating-nav-list::-webkit-scrollbar-thumb {
    background: var(--border);
    border-radius: 2px;
  }

  .floating-nav-list::-webkit-scrollbar-thumb:hover {
    background: var(--text-muted);
  }

  .main-header {
    margin-bottom: 24px;
    padding-bottom: 20px;
    border-bottom: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
  }

  .main-header-left {
    min-width: 0;
  }

  .main-title {
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: 1.6rem;
    font-weight: 800;
    margin-bottom: 6px;
  }

  .title-icon {
    display: flex;
    align-items: center;
    width: 32px;
    height: 32px;
    color: var(--accent);
  }

  .title-icon svg {
    width: 28px;
    height: 28px;
  }

  .main-subtitle {
    font-size: 0.875rem;
    color: var(--text-muted);
    padding-left: 44px;
  }

  /* ==================== Accordion ==================== */
  .accordion-list {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .accordion-item {
    border: 1px solid var(--border);
    border-radius: 10px;
    background: var(--bg-card);
    overflow: hidden;
    transition: box-shadow 0.2s;
  }

  .accordion-item.open {
    box-shadow: 0 2px 12px rgba(0,0,0,0.06);
  }

  .accordion-header {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px 18px;
    border: none;
    background: transparent;
    cursor: pointer;
    transition: background 0.15s;
    color: var(--text);
    gap: 12px;
    -webkit-user-select: none;
    user-select: none;
  }

  .accordion-header:hover {
    background: var(--bg-code);
  }

  .accordion-right {
    display: flex;
    align-items: center;
    gap: 4px;
    flex-shrink: 0;
  }

  .header-copy-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    border: none;
    background: transparent;
    border-radius: 6px;
    cursor: pointer;
    color: var(--text-muted);
    opacity: 0.4;
    transition: all 0.15s;
    flex-shrink: 0;
  }

  .accordion-header:hover .header-copy-btn {
    opacity: 1;
  }

  .header-copy-btn:hover {
    background: var(--tag-bg);
    color: var(--accent);
    opacity: 1;
  }

  .header-copy-btn.copied {
    color: #22c55e;
  }

  .header-copy-btn.copied svg {
    stroke: #22c55e;
  }

  /* Copy toast */
  .copy-toast {
    position: fixed;
    top: calc(var(--header-h) + 16px);
    left: 50%;
    transform: translateX(-50%) translateY(-8px);
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 8px 16px;
    font-size: 0.85rem;
    font-weight: 500;
    color: #22c55e;
    box-shadow: 0 4px 16px rgba(0,0,0,0.1);
    z-index: 999;
    opacity: 0;
    transition: opacity 0.2s, transform 0.2s;
    pointer-events: none;
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .copy-toast.show {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }

  .accordion-title {
    display: flex;
    align-items: center;
    gap: 10px;
    min-width: 0;
    flex: 1;
  }

  .accordion-name {
    font-family: 'JetBrains Mono', 'Fira Code', ui-monospace, monospace;
    font-size: 1rem;
    font-weight: 700;
    color: var(--accent);
    white-space: nowrap;
  }

  .accordion-cat {
    font-size: 0.7rem;
    padding: 2px 8px;
    border-radius: 9999px;
    font-weight: 600;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .cat-file { background: #fff7ed; color: #c2410c; }
  .cat-text { background: #f3f4f6; color: #4b5563; }
  .cat-system { background: #eff6ff; color: #1d4ed8; }
  .cat-network { background: #f0fdf4; color: #15803d; }
  .cat-process { background: #fef2f2; color: #b91c1c; }
  .cat-session { background: #f5f3ff; color: #6d28d9; }
  .cat-config { background: #f0fdfa; color: #0f766e; }
  .cat-review { background: #fdf2f8; color: #be185d; }
  .cat-cli { background: #eef2ff; color: #4338ca; }
  .cat-package { background: #fffbeb; color: #b45309; }

  [data-theme="dark"] .cat-file { background: #431407; color: #fb923c; }
  [data-theme="dark"] .cat-text { background: #1f2937; color: #9ca3af; }
  [data-theme="dark"] .cat-system { background: #172554; color: #60a5fa; }
  [data-theme="dark"] .cat-network { background: #052e16; color: #4ade80; }
  [data-theme="dark"] .cat-process { background: #450a0a; color: #f87171; }
  [data-theme="dark"] .cat-session { background: #2e1065; color: #a78bfa; }
  [data-theme="dark"] .cat-config { background: #042f2e; color: #2dd4bf; }
  [data-theme="dark"] .cat-review { background: #500724; color: #f472b6; }
  [data-theme="dark"] .cat-cli { background: #1e1b4b; color: #a5b4fc; }
  [data-theme="dark"] .cat-package { background: #451a03; color: #fbbf24; }

  .accordion-alias {
    font-size: 0.75rem;
    color: var(--text-muted);
    font-family: 'JetBrains Mono', 'Fira Code', ui-monospace, monospace;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .accordion-chevron {
    flex-shrink: 0;
    transition: transform 0.25s ease;
    color: var(--text-muted);
  }

  .accordion-item.open .accordion-chevron {
    transform: rotate(180deg);
  }

  .accordion-body {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 0.3s ease;
  }

  .accordion-item.open .accordion-body {
    grid-template-rows: 1fr;
  }

  .accordion-content {
    overflow: hidden;
  }

  .accordion-content-inner {
    padding: 4px 24px 28px;
  }

  /* Skeleton loading */
  @keyframes skeleton-pulse {
    0% { opacity: 0.6; }
    50% { opacity: 0.3; }
    100% { opacity: 0.6; }
  }

  .skeleton-item {
    height: 52px;
    background: var(--bg-code);
    border-radius: 10px;
    animation: skeleton-pulse 1.5s ease-in-out infinite;
    margin-bottom: 6px;
  }

  .cmd-tags { display: flex; flex-wrap: wrap; gap: 6px; margin-top: 5px; margin-bottom: 12px; }
  .cmd-tag {
    font-size: 0.7rem;
    padding: 2px 10px;
    border-radius: 6px;
    background: var(--bg-code);
    color: var(--accent);
    border: 1px solid var(--border);
    font-weight: 500;
    letter-spacing: 0.02em;
  }

  .cmd-desc {
    line-height: 1.75;
    margin-bottom: 14px;
    font-size: 0.925rem;
  }

  .cmd-label {
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    opacity: 0.5;
    margin-bottom: 4px;
  }

  .cmd-syntax-block {
    background: var(--bg-code);
    border-radius: 8px;
    padding: 12px 14px;
    margin-bottom: 10px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
  }

  .cmd-syntax-block code,
  .cmd-example-block code {
    font-family: 'JetBrains Mono', 'Fira Code', ui-monospace, monospace;
    font-size: 0.85rem;
    word-break: break-all;
  }

  .cmd-example-block {
    background: var(--bg-code);
    border-radius: 8px;
    padding: 12px 14px;
    margin-bottom: 10px;
  }

  .copy-btn {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 4px 10px;
    border-radius: 6px;
    border: 1px solid var(--border);
    background: var(--bg-card);
    font-size: 0.72rem;
    cursor: pointer;
    transition: all 0.15s;
    white-space: nowrap;
    flex-shrink: 0;
    color: var(--text);
  }

  .copy-btn:hover { border-color: var(--accent-light); color: var(--accent); }
  .copy-btn.copied { border-color: #22c55e; color: #22c55e; }

  .cmd-scenarios { margin-bottom: 12px; }
  .cmd-scenarios ul { list-style: none; padding: 0; }
  .cmd-scenarios li {
    position: relative;
    padding-left: 20px;
    margin-bottom: 6px;
    font-size: 0.875rem;
    line-height: 1.65;
  }
  .cmd-scenarios li::before {
    content: '💡';
    position: absolute;
    left: 0;
    font-size: 0.7rem;
  }

  .cmd-related {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    align-items: center;
  }

  .cmd-alias-tag {
    font-size: 0.78rem;
    padding: 2px 8px;
    border-radius: 6px;
    background: var(--bg-code);
    font-family: 'JetBrains Mono', 'Fira Code', ui-monospace, monospace;
  }

  /* Variant tabs */
  .variant-tabs {
    display: flex;
    gap: 0;
    border-bottom: 2px solid var(--border);
    margin-bottom: 10px;
  }
  .variant-tab {
    padding: 6px 14px;
    font-size: 0.8rem;
    font-weight: 600;
    cursor: pointer;
    border: none;
    background: transparent;
    border-bottom: 2px solid transparent;
    margin-bottom: -2px;
    color: var(--text-muted);
    transition: all 0.15s;
  }
  .variant-tab.active { border-bottom-color: var(--accent); color: var(--accent); }
  .variant-panel { display: none; }
  .variant-panel.active { display: block; }

  /* ==================== Floating Nav ==================== */
  .floating-nav {
    position: fixed;
    right: 12px;
    top: 20%;
    width: 190px;
    background: transparent;
    border: none;
    z-index: 90;
    display: flex;
    flex-direction: column;
  }

  .floating-nav-title {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--text-muted);
    padding: 0 0 8px;
    letter-spacing: 0.04em;
    border-bottom: 1px solid var(--border);
    margin-bottom: 4px;
  }

  .floating-nav-list {
    overflow-y: auto;
    padding: 4px 0;
    display: flex;
    flex-direction: column;
    gap: 4px;
    max-height: 60vh;
  }

  .floating-nav-link {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 7px 10px 7px 14px;
    border-radius: 6px;
    text-decoration: none;
    color: var(--text-muted);
    font-size: 16px;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Noto Sans SC', sans-serif;
    transition: color 0.15s, background 0.15s, border-color 0.15s;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    line-height: 1.7;
    border-left: 2px solid transparent;
  }

  .floating-nav-link:hover {
    color: var(--text);
    background: var(--bg-code);
  }

  .floating-nav-link.active {
    color: var(--accent);
    font-weight: 600;
    border-left-color: var(--accent);
    background: var(--tag-bg);
  }

