---
import Layout from '../layouts/Layout.astro';

interface Props {
  title?: string;
  description?: string;
}
const { title = 'Cmd Cheatsheet', description = '命令速查站' } = Astro.props;
---
<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="icon" type="image/svg+xml" href="/cmd-cheatsheet/favicon.svg" />
  <script src="https://code.iconify.design/iconify-icon/2.1.0/iconify-icon.min.js"></script>
  <slot name="head" />
</head>
<body>
  <div class="page-loading-bar" id="page-loading-bar"></div>
  <div class="app-shell" id="app-shell">

    {/* ===== Persistent Header (outside routing) ===== */}
    <header class="site-header" id="site-header">
      <div class="header-left">
        <a href="/cmd-cheatsheet/" class="header-logo" data-nav="home">
          <span class="header-logo-icon">
            <iconify-icon icon="mdi:console" width="24" height="24"></iconify-icon>
          </span>
          <span class="header-logo-text">Cmd Cheatsheet</span>
        </a>
      </div>

      <div class="header-search">
        <a class="header-search-btn" href="/cmd-cheatsheet/" data-nav="home">
          <iconify-icon icon="mdi:magnify" width="16" height="16"></iconify-icon>
          <span>搜索命令...</span>
          <span class="header-search-kbd">Ctrl K</span>
        </a>
      </div>

      <div class="header-right">
        <a class="header-link" href="/cmd-cheatsheet/" data-nav="home" title="首页">
          <iconify-icon icon="mdi:home-outline" width="18" height="18"></iconify-icon>
          <span>首页</span>
        </a>
        <a class="header-link" href="/cmd-cheatsheet/overview" data-nav="overview" title="总览">
          <iconify-icon icon="mdi:view-dashboard-outline" width="18" height="18"></iconify-icon>
          <span>总览</span>
        </a>
        <span class="header-stat-badge" id="header-stat-badge"></span>
        <a class="header-link" href="https://github.com/why-qw1ko/cmd-cheatsheet/releases" target="_blank" rel="noopener" title="更新日志">
          <iconify-icon icon="mdi:file-document-outline" width="16" height="16"></iconify-icon>
          <span>更新日志</span>
        </a>
        <a class="header-link" href="https://github.com/why-qw1ko/cmd-cheatsheet/issues" target="_blank" rel="noopener" title="反馈问题">
          <iconify-icon icon="mdi:alert-circle-outline" width="18" height="18"></iconify-icon>
          <span>反馈</span>
        </a>
        <a class="header-link" href="https://github.com/why-qw1ko/cmd-cheatsheet" target="_blank" rel="noopener" title="GitHub">
          <iconify-icon icon="mdi:github" width="18" height="18"></iconify-icon>
        </a>
        <button class="header-btn" id="theme-toggle-header" title="切换主题">
          <span class="theme-icon-light">
            <iconify-icon icon="mdi:weather-sunny" width="20" height="20"></iconify-icon>
          </span>
          <span class="theme-icon-dark">
            <iconify-icon icon="mdi:weather-night" width="20" height="20"></iconify-icon>
          </span>
        </button>
      </div>
    </header>

    {/* ===== Persistent Mobile Top Bar ===== */}
    <div class="mobile-topbar" id="mobile-topbar">
      <button class="mobile-btn" id="mobile-menu-btn" aria-label="菜单">
        <iconify-icon icon="mdi:menu" width="22" height="22"></iconify-icon>
      </button>
      <span class="mobile-topbar-title" id="mobile-topbar-title">Cmd Cheatsheet</span>
      <button class="mobile-btn" id="mobile-theme-btn" aria-label="主题">
        <span class="theme-icon-light"><iconify-icon icon="mdi:weather-sunny" width="20" height="20"></iconify-icon></span>
        <span class="theme-icon-dark"><iconify-icon icon="mdi:weather-night" width="20" height="20"></iconify-icon></span>
      </button>
    </div>
    <div class="mobile-overlay" id="mobile-overlay"></div>

    {/* ===== Routed Content ===== */}
    <div id="page-content"><slot /></div>
  </div>
</body>
</html>

<style is:global>
  @import "tailwindcss";

  :root {
    --sidebar-w: 220px;
    --accent: #6366f1;
    --accent-light: #818cf8;
    --bg: #f8fafc;
    --bg-card: #ffffff;
    --bg-code: #f1f5f9;
    --border: #e2e8f0;
    --text: #1e293b;
    --text-muted: #64748b;
    --tag-bg: #eef2ff;
    --tag-text: #4f46e5;
    --header-h: 56px;
  }

  [data-theme="dark"] {
    --bg: #0f172a;
    --bg-card: #1e293b;
    --bg-code: #0f172a;
    --border: #334155;
    --text: #f1f5f9;
    --text-muted: #94a3b8;
    --tag-bg: #1e1b4b;
    --tag-text: #a5b4fc;
  }

  /* ==================== Page Loading Bar ==================== */
  .page-loading-bar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    z-index: 9999;
    background: linear-gradient(90deg, #ff0080, #ff8c00, #40e0d0, #6366f1, #ff0080);
    background-size: 200% 100%;
    transform: scaleX(0);
    transform-origin: left;
    opacity: 0;
    transition: transform 0.3s ease, opacity 0.2s;
  }

  .page-loading-bar.loading {
    opacity: 1;
    transform: scaleX(0.7);
    animation: loading-rainbow 1.2s linear infinite;
  }

  .page-loading-bar.done {
    opacity: 1;
    transform: scaleX(1);
    animation: loading-rainbow 0.6s linear infinite;
    transition: transform 0.2s ease;
  }

  @keyframes loading-rainbow {
    0% { background-position: 0% 0%; }
    100% { background-position: 200% 0%; }
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  html {
    scroll-behavior: smooth;
    background: var(--bg);
    color: var(--text);
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Noto Sans SC', sans-serif;
  }

  body {
    min-height: 100vh;
    overflow-x: hidden;
  }

  .app-shell {
    display: flex;
    flex-direction: column;
    min-height: 100vh;
  }

  /* ==================== Header ==================== */
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: var(--header-h);
    background: var(--bg-card);
    border-bottom: 1px solid var(--border);
    z-index: 300;
    display: flex;
    align-items: center;
    padding: 0 24px;
    gap: 16px;
  }

  .header-left {
    display: flex;
    align-items: center;
    gap: 12px;
    min-width: 200px;
  }

  .header-logo {
    display: flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    color: var(--text);
  }

  .header-logo-icon {
    display: flex;
    align-items: center;
    color: var(--accent);
  }

  .header-logo-text {
    font-size: 1.05rem;
    font-weight: 700;
    white-space: nowrap;
  }

  .header-search {
    flex: 1;
    max-width: 480px;
    position: relative;
  }

  .header-search-btn {
    width: 100%;
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 7px 14px;
    border: 1px solid var(--border);
    border-radius: 8px;
    background: var(--bg);
    cursor: pointer;
    transition: border-color 0.15s;
    color: var(--text-muted);
    font-size: 0.875rem;
  }

  .header-search-btn:hover {
    border-color: var(--accent-light);
  }

  .header-search-btn svg {
    flex-shrink: 0;
    opacity: 0.5;
  }

  .header-search-kbd {
    margin-left: auto;
    font-size: 0.72rem;
    padding: 2px 6px;
    border-radius: 4px;
    border: 1px solid var(--border);
    background: var(--bg-card);
    color: var(--text-muted);
    font-family: inherit;
  }

  .header-right {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-left: auto;
  }

  .header-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border: none;
    background: transparent;
    border-radius: 8px;
    cursor: pointer;
    color: var(--text-muted);
    transition: all 0.15s;
    text-decoration: none;
  }

  .header-btn:hover {
    background: var(--bg-code);
    color: var(--text);
  }

  .header-github-link {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 6px 12px;
    border: 1px solid var(--border);
    border-radius: 8px;
    background: transparent;
    text-decoration: none;
    color: var(--text-muted);
    font-size: 0.8rem;
    font-weight: 500;
    transition: all 0.15s;
    white-space: nowrap;
  }

  .header-github-link:hover {
    border-color: var(--accent-light);
    color: var(--text);
  }

  .header-link {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 6px 12px;
    border-radius: 8px;
    background: transparent;
    text-decoration: none;
    color: var(--text-muted);
    font-size: 0.8rem;
    font-weight: 500;
    transition: all 0.15s;
    white-space: nowrap;
    border: none;
    cursor: pointer;
  }

  .header-link:hover {
    background: var(--bg-code);
    color: var(--text);
  }

  .header-stat-badge {
    font-size: 0.72rem;
    padding: 4px 10px;
    border-radius: 9999px;
    background: var(--tag-bg);
    color: var(--tag-text);
    font-weight: 600;
    white-space: nowrap;
  }

  /* Theme toggle icons */
  .theme-icon-light,
  .theme-icon-dark,
  .sidebar-icon.theme-icon-light,
  .sidebar-icon.theme-icon-dark { display: none; }
  .theme-icon-light,
  .sidebar-icon.theme-icon-light { display: flex; }
  [data-theme="dark"] .theme-icon-light,
  [data-theme="dark"] .sidebar-icon.theme-icon-light { display: none; }
  [data-theme="dark"] .theme-icon-dark,
  [data-theme="dark"] .sidebar-icon.theme-icon-dark { display: flex; }

  /* ==================== Body Layout ==================== */
  .body-layout {
    display: flex;
    margin-top: var(--header-h);
    min-height: calc(100vh - var(--header-h));
  }

  /* ==================== Sidebar ==================== */
  .domain-sidebar {
    width: var(--sidebar-w);
    min-width: var(--sidebar-w);
    height: calc(100vh - var(--header-h));
    position: fixed;
    left: 0;
    top: var(--header-h);
    display: flex;
    flex-direction: column;
    background: var(--bg-card);
    border-right: 1px solid var(--border);
    z-index: 100;
    overflow-y: auto;
    padding: 16px 12px;
  }

  .sidebar-section-title {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-muted);
    padding: 8px 10px 6px;
  }

  .sidebar-nav {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .sidebar-btn {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 12px;
    border: none;
    background: transparent;
    border-radius: 10px;
    cursor: pointer;
    transition: all 0.15s;
    color: var(--text-muted);
    text-align: left;
    width: 100%;
  }

  .sidebar-btn:hover {
    background: var(--bg-code);
    color: var(--text);
  }

  .sidebar-btn.active {
    background: var(--tag-bg);
    color: var(--accent);
  }

  .sidebar-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 10px;
    background: var(--bg-code);
    flex-shrink: 0;
    transition: background 0.15s;
  }

  .sidebar-btn.active .sidebar-icon {
    background: rgba(109, 40, 217, 0.15);
  }

  .sidebar-icon svg {
    width: 20px;
    height: 20px;
  }

  .sidebar-btn-text {
    display: flex;
    flex-direction: column;
    min-width: 0;
  }

  .sidebar-btn-label {
    font-size: 0.88rem;
    font-weight: 600;
    line-height: 1.3;
  }

  .sidebar-btn-count {
    font-size: 0.72rem;
    opacity: 0.6;
  }

  .sidebar-divider {
    height: 1px;
    background: var(--border);
    margin: 12px 10px;
  }

  .sidebar-footer {
    margin-top: auto;
    padding-top: 8px;
    border-top: 1px solid var(--border);
  }

  .sidebar-footer .sidebar-btn {
    padding: 8px 12px;
  }

  /* ==================== Main Content ==================== */
  .main-area {
    flex: 1;
    margin-left: var(--sidebar-w);
    margin-right: 280px;
    padding: 32px 48px 80px;
    min-width: 0;
    max-width: 1000px;
  }

  .toggle-all-btn {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    border: 1px solid var(--border);
    background: var(--bg-card);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--text-muted);
    transition: all 0.2s;
    flex-shrink: 0;
  }

  .toggle-all-btn:hover {
    border-color: var(--accent);
    color: var(--accent);
    background: var(--tag-bg);
  }

  .toggle-icon {
    transition: transform 0.3s ease;
  }

  /* Danger badges */
  .accordion-danger {
    font-size: 0.65rem;
    padding: 1px 6px;
    border-radius: 9999px;
    font-weight: 700;
    letter-spacing: 0.03em;
    flex-shrink: 0;
  }

  .danger-high {
    background: #fef2f2;
    color: #dc2626;
  }

  .danger-mid {
    background: #fffbeb;
    color: #d97706;
  }

  [data-theme="dark"] .danger-high {
    background: #450a0a;
    color: #f87171;
  }

  [data-theme="dark"] .danger-mid {
    background: #451a03;
    color: #fbbf24;
  }

  /* Letter index */
  .nav-letter-index {
    display: flex;
    flex-wrap: wrap;
    gap: 2px;
    padding: 8px 12px 4px;
    border-bottom: 1px solid var(--border);
  }

  .letter-btn {
    width: 22px;
    height: 22px;
    display: flex;
    align-items: center;
    justify-content: center;
    border: none;
    background: transparent;
    border-radius: 4px;
    cursor: pointer;
    font-size: 0.7rem;
    font-weight: 600;
    color: var(--text-muted);
    transition: all 0.1s;
  }

  .letter-btn:hover {
    background: var(--tag-bg);
    color: var(--accent);
  }

  .letter-btn.active {
    background: var(--accent);
    color: #fff;
  }

  .nav-letter-group.hidden {
    display: none;
  }

  /* Toast notifications */
  .dev-toast {
    position: fixed;
    bottom: 24px;
    left: 50%;
    transform: translateX(-50%) translateY(20px);
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 12px 20px;
    font-size: 0.9rem;
    box-shadow: 0 8px 30px rgba(0,0,0,0.12);
    z-index: 999;
    opacity: 0;
    transition: opacity 0.3s, transform 0.3s;
    pointer-events: none;
  }

  .dev-toast.show {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }

  /* Tag filter bar */
  .tag-filter-bar {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 16px;
    margin-bottom: 16px;
    background: var(--tag-bg);
    border: 1px solid var(--border);
    border-radius: 10px;
    font-size: 0.85rem;
  }

  .tag-filter-label {
    color: var(--text-muted);
    font-size: 0.8rem;
  }

  .tag-filter-tag {
    background: var(--accent);
    color: #fff;
    padding: 2px 10px;
    border-radius: 6px;
    font-weight: 600;
    font-size: 0.8rem;
  }

  .tag-filter-clear {
    margin-left: auto;
    border: none;
    background: transparent;
    color: var(--text-muted);
    cursor: pointer;
    font-size: 0.8rem;
    padding: 4px 8px;
    border-radius: 6px;
    transition: all 0.15s;
  }

  .tag-filter-tag.cat {
    background: var(--accent-light);
  }

  /* Cross-platform equivalents in accordion */
  .cmd-cross-platform {
    margin-bottom: 12px;
  }

  .cp-equiv-list {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .cp-equiv-item {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 4px 12px;
    border-radius: 8px;
    background: var(--bg-code);
    border: 1px solid var(--border);
    font-size: 0.82rem;
    cursor: pointer;
    transition: all 0.15s;
  }

  .cp-equiv-item:hover {
    border-color: var(--accent);
    background: var(--tag-bg);
  }

  .cp-equiv-item code {
    font-family: 'JetBrains Mono', 'Fira Code', ui-monospace, monospace;
    font-weight: 600;
    color: var(--accent);
  }

  .cp-equiv-item small {
    color: var(--text-muted);
    font-size: 0.72rem;
  }

  /* Cross-platform view */
  .cp-view-list {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .cp-view-group {
    border: 1px solid var(--border);
    border-radius: 10px;
    background: var(--bg-card);
    padding: 14px 18px;
    transition: box-shadow 0.2s;
  }

  .cp-view-group:hover {
    box-shadow: 0 2px 12px rgba(0,0,0,0.06);
  }

  .cp-view-label {
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 8px;
  }

  .cp-view-items {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .cp-view-item {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 6px 14px;
    border-radius: 8px;
    background: var(--bg-code);
    border: 1px solid var(--border);
    font-size: 0.85rem;
    cursor: pointer;
    transition: all 0.15s;
  }

  .cp-view-item:hover {
    border-color: var(--accent);
    background: var(--tag-bg);
  }

  .cp-view-item code {
    font-family: 'JetBrains Mono', 'Fira Code', ui-monospace, monospace;
    font-weight: 600;
    color: var(--accent);
  }

  .nav-letter {
    font-size: 0.7rem;
    font-weight: 700;
    color: var(--text-muted);
    padding: 8px 10px 2px;
    letter-spacing: 0.04em;
  }

  /* Nav scrollbar */
  .floating-nav-list::-webkit-scrollbar {
    width: 4px;
  }

  .floating-nav-list::-webkit-scrollbar-track {
    background: transparent;
  }

  .floating-nav-list::-webkit-scrollbar-thumb {
    background: var(--border);
    border-radius: 2px;
  }

  .floating-nav-list::-webkit-scrollbar-thumb:hover {
    background: var(--text-muted);
  }

  .main-header {
    margin-bottom: 24px;
    padding-bottom: 20px;
    border-bottom: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
  }

  .main-header-left {
    min-width: 0;
  }

  .main-title {
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: 1.6rem;
    font-weight: 800;
    margin-bottom: 6px;
  }

  .title-icon {
    display: flex;
    align-items: center;
    width: 32px;
    height: 32px;
    color: var(--accent);
  }

  .title-icon svg {
    width: 28px;
    height: 28px;
  }

  .main-subtitle {
    font-size: 0.875rem;
    color: var(--text-muted);
    padding-left: 44px;
  }

  /* ==================== Accordion ==================== */
  .accordion-list {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .accordion-item {
    border: 1px solid var(--border);
    border-radius: 10px;
    background: var(--bg-card);
    overflow: hidden;
    transition: box-shadow 0.2s;
  }

  .accordion-item.open {
    box-shadow: 0 2px 12px rgba(0,0,0,0.06);
  }

  .accordion-header {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px 18px;
    border: none;
    background: transparent;
    cursor: pointer;
    transition: background 0.15s;
    color: var(--text);
    gap: 12px;
    -webkit-user-select: none;
    user-select: none;
  }

  .accordion-header:hover {
    background: var(--bg-code);
  }

  .accordion-right {
    display: flex;
    align-items: center;
    gap: 4px;
    flex-shrink: 0;
  }

  .header-copy-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    border: none;
    background: transparent;
    border-radius: 6px;
    cursor: pointer;
    color: var(--text-muted);
    opacity: 0.4;
    transition: all 0.15s;
    flex-shrink: 0;
  }

  .accordion-header:hover .header-copy-btn {
    opacity: 1;
  }

  .header-copy-btn:hover {
    background: var(--tag-bg);
    color: var(--accent);
    opacity: 1;
  }

  .header-copy-btn.copied {
    color: #22c55e;
  }

  .header-copy-btn.copied svg {
    stroke: #22c55e;
  }

  /* Copy toast */
  .copy-toast {
    position: fixed;
    top: calc(var(--header-h) + 16px);
    left: 50%;
    transform: translateX(-50%) translateY(-8px);
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 8px 16px;
    font-size: 0.85rem;
    font-weight: 500;
