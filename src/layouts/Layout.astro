---
interface Props {
  title?: string;
  description?: string;
}
const { title = 'Cmd Cheatsheet', description = '命令速查站' } = Astro.props;
---
<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="icon" type="image/svg+xml" href="/cmd-cheatsheet/favicon.svg" />
  <slot name="head" />
</head>
<body>
  {/* Mobile top bar */}
  <div class="mobile-topbar" id="mobile-topbar">
    <button class="mobile-menu-btn" id="mobile-menu-btn" aria-label="打开菜单">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
    </button>
    <span class="mobile-topbar-title" id="mobile-topbar-title">Linux</span>
    <button class="mobile-nav-btn" id="mobile-nav-btn" aria-label="命令导航">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><circle cx="12" cy="6" r="1.5"/><circle cx="12" cy="12" r="1.5"/><circle cx="12" cy="18" r="1.5"/><line x1="15" y1="6" x2="21" y2="6"/><line x1="15" y1="12" x2="21" y2="12"/><line x1="15" y1="18" x2="21" y2="18"/></svg>
    </button>
  </div>

  {/* Mobile overlay */}
  <div class="mobile-overlay" id="mobile-overlay"></div>

  <div class="app-shell">
    <slot />
  </div>
</body>
</html>

<style is:global>
  @import "tailwindcss";

  :root {
    --sidebar-w: 72px;
    --anchor-w: 200px;
    --accent: #6d28d9;
    --accent-light: #8b5cf6;
    --bg: #f8fafc;
    --bg-card: #ffffff;
    --bg-code: #f1f5f9;
    --border: #e2e8f0;
    --text: #1e293b;
    --text-muted: #64748b;
    --tag-bg: #ede9fe;
    --tag-text: #6d28d9;
  }

  [data-theme="dark"] {
    --bg: #0f172a;
    --bg-card: #1e293b;
    --bg-code: #0f172a;
    --border: #334155;
    --text: #f1f5f9;
    --text-muted: #94a3b8;
    --tag-bg: #3b0764;
    --tag-text: #c4b5fd;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  html {
    scroll-behavior: smooth;
    background: var(--bg);
    color: var(--text);
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Noto Sans SC', sans-serif;
  }

  body {
    min-height: 100vh;
    overflow-x: hidden;
  }

  .app-shell {
    display: flex;
    min-height: 100vh;
  }

  /* Mobile top bar — hidden on desktop */
  .mobile-topbar {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: 52px;
    background: var(--bg-card);
    border-bottom: 1px solid var(--border);
    z-index: 200;
    align-items: center;
    justify-content: space-between;
    padding: 0 12px;
  }

  .mobile-topbar-title {
    font-weight: 700;
    font-size: 1rem;
    color: var(--accent);
  }

  .mobile-menu-btn,
  .mobile-nav-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border: none;
    background: transparent;
    border-radius: 8px;
    cursor: pointer;
    color: var(--text);
    transition: background 0.15s;
  }

  .mobile-menu-btn:hover,
  .mobile-nav-btn:hover {
    background: var(--bg-code);
  }

  .mobile-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.4);
    z-index: 149;
  }

  .mobile-overlay.visible {
    display: block;
  }

  /* ===== Desktop (default) ===== */
  /* Scrollbar */
  ::-webkit-scrollbar { width: 6px; height: 6px; }
  ::-webkit-scrollbar-track { background: transparent; }
  ::-webkit-scrollbar-thumb { background: var(--border); border-radius: 3px; }
  ::-webkit-scrollbar-thumb:hover { background: var(--text-muted); }

  /* ===== Mobile: ≤768px ===== */
  @media (max-width: 768px) {
    .mobile-topbar {
      display: flex;
    }

    .app-shell {
      padding-top: 52px;
    }

    /* Sidebar: off-canvas drawer */
    .domain-sidebar {
      position: fixed !important;
      left: 0;
      top: 0;
      width: 200px !important;
      min-width: 200px !important;
      height: 100vh;
      transform: translateX(-100%);
      transition: transform 0.25s ease;
      z-index: 150;
      flex-direction: row;
      flex-wrap: wrap;
      align-content: flex-start;
      padding: 16px 12px;
      gap: 8px;
    }

    .domain-sidebar.open {
      transform: translateX(0);
    }

    .domain-sidebar .sidebar-logo {
      width: 100%;
      margin-bottom: 12px;
    }

    .domain-sidebar .sidebar-nav {
      flex-direction: row;
      flex-wrap: wrap;
      gap: 8px;
      width: 100%;
    }

    .domain-sidebar .sidebar-btn {
      width: auto;
      flex-direction: row;
      gap: 8px;
      padding: 10px 14px;
      border-radius: 10px;
      justify-content: flex-start;
    }

    .domain-sidebar .sidebar-label {
      font-size: 0.9rem;
    }

    .domain-sidebar .sidebar-footer {
      width: 100%;
      margin-top: 16px;
      padding-top: 12px;
    }

    .domain-sidebar .theme-toggle {
      flex-direction: row;
      gap: 8px;
      width: auto;
      padding: 10px 14px;
    }

    /* Main area: full width */
    .main-area {
      margin-left: 0 !important;
      margin-right: 0 !important;
      padding: 20px 16px 100px !important;
      max-width: 100% !important;
      width: 100%;
    }

    /* Right nav: bottom sheet */
    .command-nav {
      position: fixed !important;
      left: 0;
      right: 0;
      bottom: 0;
      top: auto !important;
      width: 100% !important;
      min-width: 100% !important;
      height: auto !important;
      max-height: 60vh;
      border-left: none !important;
      border-top: 1px solid var(--border);
      border-radius: 16px 16px 0 0;
      transform: translateY(100%);
      transition: transform 0.25s ease;
      z-index: 160;
      padding: 16px;
    }

    .command-nav.open {
      transform: translateY(0);
    }

    .command-nav .nav-title {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 0 12px;
    }

    .command-nav .nav-title::after {
      content: '✕';
      font-size: 1rem;
      cursor: pointer;
      padding: 4px 8px;
      border-radius: 6px;
      transition: background 0.15s;
    }

    .command-nav .nav-title:hover::after {
      background: var(--bg-code);
    }

    .command-nav .nav-list {
      max-height: 50vh;
      flex-wrap: wrap;
      flex-direction: row;
      gap: 6px;
    }

    .command-nav .nav-link {
      font-size: 0.78rem;
      padding: 4px 10px;
      border-radius: 20px;
      background: var(--bg-code);
    }
  }

  /* ===== Small mobile: ≤480px ===== */
  @media (max-width: 480px) {
    .main-area {
      padding: 16px 12px 100px !important;
    }

    .main-title {
      font-size: 1.3rem !important;
    }

    .accordion-header {
      padding: 12px 14px !important;
    }

    .accordion-name {
      font-size: 0.95rem !important;
    }

    .accordion-alias {
      display: none;
    }

    .cmd-syntax-block {
      flex-direction: column;
      align-items: flex-start;
    }

    .copy-btn {
      align-self: flex-end;
    }
  }
</style>

<script>
  // Mobile menu toggle
  const menuBtn = document.getElementById('mobile-menu-btn');
  const navBtn = document.getElementById('mobile-nav-btn');
  const overlay = document.getElementById('mobile-overlay');
  const sidebar = document.getElementById('domain-sidebar');
  const nav = document.getElementById('command-nav');

  function closeAll() {
    sidebar?.classList.remove('open');
    nav?.classList.remove('open');
    overlay?.classList.remove('visible');
  }

  menuBtn?.addEventListener('click', () => {
    const isOpen = sidebar?.classList.contains('open');
    closeAll();
    if (!isOpen) {
      sidebar?.classList.add('open');
      overlay?.classList.add('visible');
    }
  });

  navBtn?.addEventListener('click', () => {
    const isOpen = nav?.classList.contains('open');
    closeAll();
    if (!isOpen) {
      nav?.classList.add('open');
      overlay?.classList.add('visible');
    }
  });

  overlay?.addEventListener('click', closeAll);

  // Close sidebar on domain switch (mobile)
  document.addEventListener('domain-switched', closeAll);
</script>
