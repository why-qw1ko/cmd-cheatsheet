<script>
  // Theme
  const root = document.documentElement;
  const saved = localStorage.getItem('theme');
  if (saved) root.setAttribute('data-theme', saved);
  else if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
    root.setAttribute('data-theme', 'dark');
  }

  // SPA Router — persistent header, swap #page-content
  function initRouter() {
    const bar = document.getElementById('page-loading-bar');
    const content = document.getElementById('page-content');
    if (!bar || !content) return;

    function showBar() { bar.classList.remove('done'); bar.classList.add('loading'); }
    function hideBar() { bar.classList.remove('loading'); bar.classList.add('done'); setTimeout(() => bar.classList.remove('done'), 500); }

    // Extract #page-content from fetched HTML
    function extractContent(html: string): string | null {
      const parser = new DOMParser();
      const doc = parser.parseFromString(html, 'text/html');
      const el = doc.getElementById('page-content');
      return el ? el.innerHTML : null;
    }

    // Re-execute scripts inside #page-content
    function reExecuteScripts() {
      // Abort previous page's event listeners
      if ((window as any).__pageAbort) (window as any).__pageAbort.abort();
      (window as any).__pageAbort = new AbortController();

      const scripts = content!.querySelectorAll('script');
      scripts.forEach(old => {
        const s = document.createElement('script');
        for (const attr of old.attributes) s.setAttribute(attr.name, attr.value);
        if (old.textContent) s.textContent = old.textContent;
        old.parentNode!.replaceChild(s, old);
      });

      // Update active nav link
      updateActiveNav();
    }

    // Navigate to a URL via SPA
    async function spaNavigate(url: string, pushState = true) {
      if (url === location.pathname + location.search + location.hash) return;
      showBar();
      try {
        const resp = await fetch(url, { headers: { 'Accept': 'text/html' } });
        if (!resp.ok) { window.location.href = url; return; }
        const html = await resp.text();
        const newContent = extractContent(html);
        if (!newContent) { window.location.href = url; return; }

        content!.innerHTML = newContent;
        if (pushState) history.pushState({}, '', url);
        reExecuteScripts();
        window.scrollTo({ top: 0 });
        hideBar();

        // Update document title
        const titleMatch = html.match(/<title>(.*?)<\/title>/);
        if (titleMatch) document.title = titleMatch[1];
      } catch {
        window.location.href = url;
      }
    }

    // Update active nav link in header
    function updateActiveNav() {
      const path = location.pathname;
      document.querySelectorAll('[data-nav]').forEach(el => {
        const nav = (el as HTMLElement).dataset.nav;
        const isActive = (nav === 'home' && (path === '/cmd-cheatsheet/' || path === '/cmd-cheatsheet')) ||
                         (nav === 'overview' && path.includes('/overview'));
        el.classList.toggle('active', !!isActive);
      });
      // Update mobile title
      const mt = document.getElementById('mobile-topbar-title');
      if (mt) mt.textContent = path.includes('/overview') ? '总览' : 'Cmd Cheatsheet';
    }

    // Intercept clicks on internal links
    document.addEventListener('click', (e) => {
      const link = (e.target as HTMLElement).closest('a');
      if (!link) return;
      const href = link.getAttribute('href');
      if (!href || href.startsWith('http') || href.startsWith('#') || href.startsWith('mailto:') || link.target === '_blank') return;
      // Already on this page
      const fullPath = new URL(href, location.origin).pathname + new URL(href, location.origin).search;
      if (fullPath === location.pathname + location.search) return;
      e.preventDefault();
      spaNavigate(fullPath);
    });

    // Browser back/forward
    window.addEventListener('popstate', () => {
      spaNavigate(location.pathname + location.search + location.hash, false);
    });
  }
  initRouter();

  // Mobile menu
  const menuBtn = document.getElementById('mobile-menu-btn');
  const overlay = document.getElementById('mobile-overlay');
  const sidebar = document.getElementById('domain-sidebar');

  function closeSidebar() {
    sidebar?.classList.remove('open');
    overlay?.classList.remove('visible');
  }

  menuBtn?.addEventListener('click', () => {
    const isOpen = sidebar?.classList.contains('open');
    closeSidebar();
    if (!isOpen) {
      sidebar?.classList.add('open');
      overlay?.classList.add('visible');
    }
  });

  overlay?.addEventListener('click', closeSidebar);
  document.addEventListener('domain-switched', closeSidebar);
</script>
