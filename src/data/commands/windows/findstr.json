{
  "name": "findstr",
  "aliases": ["Select-String"],
  "domain": "windows",
  "category": "text",
  "tags": ["search", "grep", "text", "regex"],
  "description": "在文件中搜索字符串。CMD 用 findstr，PowerShell 用 Select-String（别名 sls）。类似 Linux 的 grep。",
  "variants": [
    { "name": "CMD", "syntax": "findstr [/I] [/R] 模式 文件...", "example": "findstr /I /N \"error\" *.log" },
    { "name": "PowerShell", "syntax": "Select-String [-Pattern] 模式 [-Path] 文件", "example": "Select-String -Pattern 'ERROR' -Path *.log" }
  ],
  "scenarios": [
    "在日志中搜索错误信息",
    "递归搜索代码中的关键字",
    "用正则表达式匹配文本"
  ],
  "related": ["dir", "type"],
  "since": "Windows NT"
}
