{
  "name": "type",
  "aliases": [
    "Get-Content"
  ],
  "domain": "windows",
  "category": "text",
  "tags": [
    "file",
    "read",
    "view",
    "cat"
  ],
  "description": "显示文本文件内容。CMD 中为 type，PowerShell 中 Get-Content 功能更强大。",
  "variants": [
    {
      "name": "CMD",
      "syntax": "type 文件名",
      "example": "type config.txt"
    },
    {
      "name": "PowerShell",
      "syntax": "Get-Content [-Path] 文件名 [-Tail N]",
      "example": "Get-Content -Path log.txt -Tail 50"
    }
  ],
  "scenarios": [
    "快速查看配置文件内容",
    "查看日志文件最后几行",
    "配合管道处理文本"
  ],
  "related": [
    "more",
    "findstr",
    "Select-String"
  ],
  "example": "Get-Content -Path .\\app.log -Tail 20 -Wait"
}