  "variants": [
    { "name": "CMD", "syntax": "del [/P] [/F] 文件...", "example": "del /F /Q *.tmp" },
    { "name": "PowerShell", "syntax": "Remove-Item [-Path] 路径 [-Force] [-Recurse]", "example": "Remove-Item -Path .\\*.log -Force" }
  ],
  "scenarios": [
    "清理临时文件",
    "批量删除特定类型文件",
    "强制删除只读文件"
  ],
