{
  "name": "netstat",
  "aliases": [],
  "domain": "windows",
  "category": "network",
  "tags": ["network", "port", "connection", "socket", "tcp"],
  "description": "显示网络连接、监听端口、路由表和协议统计。排查网络问题和端口占用的利器。",
  "variants": [
    {
      "name": "CMD",
      "syntax": "netstat [-a] [-n] [-o] [-b]",
      "example": "netstat -ano | findstr :8080"
    },
    {
      "name": "PowerShell",
      "syntax": "Get-NetTCPConnection [-State Established]",
      "example": "Get-NetTCPConnection | Where-Object { $_.LocalPort -eq 443 }"
    }
  ],
  "scenarios": [
    "查看哪个进程占用了某个端口",
    "检查当前所有网络连接状态",
    "排查网络连接异常",
    "监控入站/出站连接数"
  ],
  "related": ["ipconfig", "tasklist"],
  "since": "Windows NT"
}
