  "variants": [
    { "name": "CMD", "syntax": "ping [-n 次数] 目标", "example": "ping -n 10 8.8.8.8" },
    { "name": "PowerShell", "syntax": "Test-Connection [-Count 次数] 目标", "example": "Test-Connection -Count 5 8.8.8.8" }
  ],
  "scenarios": [
    "测试网络是否通畅",
    "检测到服务器的延迟",
    "持续测试网络稳定性"
  ],
