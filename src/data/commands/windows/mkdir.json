    "create",
    "folder"
  ],
  "description": "创建新目录。支持递归创建多级目录。",
  "variants": [
    {
      "name": "CMD",
      "syntax": "mkdir 目录名",
      "example": "mkdir C:\\Projects\\new-app"
    },
    {
      "name": "PowerShell",
      "syntax": "New-Item -ItemType Directory -Path 路径",
      "example": "New-Item -ItemType Directory -Path 'C:\\Projects\\new-app' -Force"
    }
  ],
  "scenarios": [
    "创建新项目目录",
    "递归创建多级目录",
    "批量创建目录结构"
  ],
  "related": [
    "rmdir",
    "cd",
    "dir"
  ],
  "example": "mkdir src\\components\\header"
}