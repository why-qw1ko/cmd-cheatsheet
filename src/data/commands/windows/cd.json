{
  "name": "cd",
  "aliases": [
    "chdir",
    "Set-Location"
  ],
  "domain": "windows",
  "category": "file",
  "tags": [
    "directory",
    "navigation",
    "path"
  ],
  "description": "切换当前目录。CMD 中为 cd，PowerShell 中 Set-Location 是其现代替代。",
  "variants": [
    {
      "name": "CMD",
      "syntax": "cd [路径]",
      "example": "cd C:\\Users\\Admin\\Documents"
    },
    {
      "name": "PowerShell",
      "syntax": "Set-Location [-Path] 路径",
      "example": "Set-Location -Path 'C:\\Program Files'"
    }
  ],
  "scenarios": [
    "切换到指定目录",
    "回到上级目录（cd ..）",
    "切换驱动器（cd /d D:\\）"
  ],
  "related": [
    "dir",
    "mkdir",
    "pushd"
  ],
  "example": "cd /d D:\\Projects"
}